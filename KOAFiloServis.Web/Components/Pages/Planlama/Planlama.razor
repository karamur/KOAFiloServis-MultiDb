@page "/planlama"
@attribute [Authorize]
@rendermode InteractiveServer
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using Microsoft.AspNetCore.Authorization
@inject IKurumPuantajService KurumPuantajService
@inject IKullaniciService KullaniciService
@inject IFirmaService FirmaService
@inject IToastService ToastService
@inject NavigationManager Navigation
@inject ILogger<Planlama> Logger

<PageTitle>Planlama</PageTitle>

@if (yukleniyor)
{
    <div class="d-flex justify-content-center align-items-center" style="height: 50vh;">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Yukleniyor...</span>
        </div>
    </div>
}
else
{
    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h4 class="mb-1"><i class="bi bi-calendar-check me-2"></i>Operasyon Planlama</h4>
                <p class="text-muted small mb-0">Gunluk sefer planlamasi - coklu slot (Sabah / Aksam / Mesai)</p>
            </div>
            <div>
                <button class="btn btn-outline-secondary me-2" @onclick="OncekiAydanKopyala">
                    <i class="bi bi-copy me-1"></i> Onceki Aydan Kopyala
                </button>
                <button class="btn btn-primary" @onclick="YeniKayitAc">
                    <i class="bi bi-plus-lg me-1"></i> Yeni Sefer
                </button>
            </div>
        </div>

        <!-- Filtreler -->
        <div class="card mb-3">
            <div class="card-body py-2">
                <div class="row g-2 align-items-end">
                    <div class="col-auto">
                        <label class="form-label small mb-1">Kurum</label>
                        <select class="form-select form-select-sm" @bind="seciliKurumId" @bind:after="FiltreDegisti">
                            <option value="">Tum Kurumlar</option>
                            @foreach (var k in kurumlar)
                            {
                                <option value="@k.Id">@k.KurumAdi</option>
                            }
                        </select>
                    </div>
                    <div class="col-auto">
                        <label class="form-label small mb-1">Slot</label>
                        <select class="form-select form-select-sm" @bind="seciliSlot" @bind:after="FiltreDegisti">
                            <option value="">Tum Slotlar</option>
                            @foreach (SeferSlot s in Enum.GetValues<SeferSlot>())
                            {
                                <option value="@((int)s)">@s</option>
                            }
                        </select>
                    </div>
                    <div class="col-auto">
                        <label class="form-label small mb-1">Yil</label>
                        <select class="form-select form-select-sm" @bind="seciliYil" @bind:after="FiltreDegisti">
                            @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 2; y--)
                            {
                                <option value="@y">@y</option>
                            }
                        </select>
                    </div>
                    <div class="col-auto">
                        <label class="form-label small mb-1">Ay</label>
                        <select class="form-select form-select-sm" @bind="seciliAy" @bind:after="FiltreDegisti">
                            @for (int a = 1; a <= 12; a++)
                            {
                                <option value="@a">@(new DateTime(2024, a, 1).ToString("MMMM"))</option>
                            }
                        </select>
                    </div>
                    <div class="col-auto">
                        <button class="btn btn-outline-secondary btn-sm" @onclick="SablonOlustur">
                            <i class="bi bi-lightning me-1"></i> Sablon Olustur
                        </button>
                    </div>
                </div>
            </div>
        </div>

        @if (kayitlar.Count == 0)
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle me-2"></i>
                Secilen donemde kayit bulunamadi. "Sablon Olustur" ile bos sablon olusturabilir veya "Yeni Sefer" ile manuel ekleyebilirsiniz.
            </div>
        }
        else
        {
            var slotGruplari = kayitlar.GroupBy(k => k.Slot).OrderBy(g => g.Key);
            @foreach (var slotGrubu in slotGruplari)
            {
                <h5 class="mt-3 mb-2">
                    <span class="badge @SlotBadgeClass(slotGrubu.Key) me-2">@slotGrubu.Key</span>
                    <small class="text-muted">@slotGrubu.Count() sefer</small>
                </h5>
                <div class="table-responsive">
                    <table class="table table-sm table-striped table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Guzergah</th>
                                <th>Arac</th>
                                <th>Sofor</th>
                                <th>Yon</th>
                                <th class="text-center">Sefer</th>
                                <th class="text-center">Gun</th>
                                <th class="text-end">Birim Gelir</th>
                                <th class="text-end">Birim Gider</th>
                                <th style="width:120px">Islem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var k in slotGrubu.OrderBy(k => k.Guzergah?.GuzergahAdi).ThenBy(k => k.Plaka))
                            {
                                <tr class="@(degisenSatirlar.Contains(k) ? "table-warning" : "")">
                                    <td>@(k.Guzergah?.GuzergahAdi ?? k.GuzergahAdi)</td>
                                    <td>@(k.Arac?.AktifPlaka ?? k.Plaka)</td>
                                    <td>@(k.Sofor != null ? $"{k.Sofor.Ad} {k.Sofor.Soyad}" : k.SoforAdi)</td>
                                    <td>@k.Yon</td>
                                    <td class="text-center">@k.SeferSayisi</td>
                                    <td class="text-center">@k.Gun</td>
                                    <td class="text-end">@k.BirimGelir.ToString("N2")</td>
                                    <td class="text-end">@k.BirimGider.ToString("N2")</td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-primary btn-sm" title="Duzenle"
                                                    @onclick="() => KayitDuzenle(k)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-outline-danger btn-sm" title="Sil"
                                                    @onclick="() => KayitSil(k)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            @if (degisenSatirlar.Any())
            {
                <div class="sticky-bottom bg-light p-3 border-top mt-3 text-end">
                    <span class="text-warning me-3">@degisenSatirlar.Count degisiklik</span>
                    <button class="btn btn-success" @onclick="TopluKaydet" disabled="@kaydediliyor">
                        <i class="bi bi-save me-1"></i> Tumunu Kaydet
                    </button>
                </div>
            }
        }
    </div>
}

@* Edit Modal *@
@if (duzenleKayit != null)
{
    <PlanlamaEditModal Kayit="duzenleKayit"
                        Kurumlar="kurumlar"
                        OnKaydet="KayitKaydetCallback"
                        OnKapat="() => duzenleKayit = null" />
}

@code {
    private bool yukleniyor = true;
    private bool kaydediliyor;
    private List<Kurum> kurumlar = new();
    private List<PuantajKayit> kayitlar = new();
    private HashSet<PuantajKayit> degisenSatirlar = new();

    private int seciliKurumId;
    private int seciliYil = DateTime.Now.Year;
    private int seciliAy = DateTime.Now.Month;
    private string seciliSlot = "";

    private PuantajKayit? duzenleKayit;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            kurumlar = await KurumPuantajService.GetAktifKurumlarAsync();
            await VeriYukle();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Planlama verisi yuklenemedi");
        }
        finally { yukleniyor = false; }
    }

    private async Task VeriYukle()
    {
        kayitlar = await KurumPuantajService.GetPuantajlarAsync(seciliYil, seciliAy, seciliKurumId);
        degisenSatirlar.Clear();
    }

    private async Task FiltreDegisti() => await VeriYukle();

    private void YeniKayitAc()
    {
        duzenleKayit = new PuantajKayit
        {
            Yil = seciliYil,
            Ay = seciliAy,
            KurumId = seciliKurumId > 0 ? seciliKurumId : null,
            Slot = string.IsNullOrEmpty(seciliSlot) ? SeferSlot.Sabah : (SeferSlot)int.Parse(seciliSlot),
            SeferSayisi = 1,
            Gun = 0
        };
    }

    private void KayitDuzenle(PuantajKayit k) => duzenleKayit = k;

    private async Task KayitKaydetCallback(PuantajKayit kayit)
    {
        duzenleKayit = null;
        await VeriYukle();
    }

    private async Task KayitSil(PuantajKayit k)
    {
        if (k.Id > 0)
        {
            await KurumPuantajService.DeletePuantajAsync(k.Id);
        }
        kayitlar.Remove(k);
        degisenSatirlar.Remove(k);
    }

    private async Task TopluKaydet()
    {
        kaydediliyor = true;
        try
        {
            await KurumPuantajService.TopluSavePuantajAsync(degisenSatirlar);
            degisenSatirlar.Clear();
            await VeriYukle();
            ToastService.ShowSuccess("Tum degisiklikler kaydedildi.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Kayit hatasi: {ex.Message}");
        }
        finally { kaydediliyor = false; }
    }

    private async Task SablonOlustur()
    {
        yukleniyor = true;
        try
        {
            kayitlar = await KurumPuantajService.SablonOlusturAsync(seciliKurumId, seciliYil, seciliAy);
            ToastService.ShowSuccess("Sablon olusturuldu.");
        }
        finally { yukleniyor = false; }
    }

    private async Task OncekiAydanKopyala()
    {
        var hedefAy = seciliAy;
        var hedefYil = seciliYil;
        var kaynakAy = hedefAy == 1 ? 12 : hedefAy - 1;
        var kaynakYil = hedefAy == 1 ? hedefYil - 1 : hedefYil;

        var kaynakKayitlar = await KurumPuantajService.GetPuantajlarAsync(kaynakYil, kaynakAy, seciliKurumId);
        foreach (var k in kaynakKayitlar)
        {
            k.Id = 0;
            k.Yil = hedefYil;
            k.Ay = hedefAy;
        }
        kayitlar.AddRange(kaynakKayitlar);
        foreach (var k in kaynakKayitlar) degisenSatirlar.Add(k);
        ToastService.ShowSuccess($"{kaynakKayitlar.Count} kayit kopyalandi. Kaydetmek icin 'Tumunu Kaydet' dugmesine basin.");
    }

    private string SlotBadgeClass(SeferSlot slot) => slot switch
    {
        SeferSlot.Sabah => "bg-warning text-dark",
        SeferSlot.Aksam => "bg-info text-dark",
        SeferSlot.Mesai => "bg-secondary",
        _ => "bg-light text-dark"
    };

}
