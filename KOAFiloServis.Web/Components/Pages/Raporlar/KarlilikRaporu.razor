@page "/karlilik-raporu"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Data
@using KOAFiloServis.Web.Services
@using KOAFiloServis.Web.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbContextFactory
@inject IFirmaService FirmaService
@inject ITasimaTedarikciService TedarikciService
@inject IAracService AracService
@inject IOperasyonelHakedisService HakedisService
@inject IAracMaliyetService MaliyetService
@inject IToastService ToastService
@attribute [Authorize]

<PageTitle>Karlılık Raporu</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-1"><i class="bi bi-graph-up-arrow me-2"></i>Karlılık Raporu</h2>
            <p class="text-muted mb-0">Kurum / Tedarikçi / Araç bazlı dönemsel kar-zarar özeti (Hakediş + Maliyet Snapshot)</p>
        </div>
    </div>

    <!-- Filtreler -->
    <div class="card mb-3">
        <div class="card-body py-3">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small">Yıl</label>
                    <select class="form-select form-select-sm" @bind="filtreYil" @bind:after="LoadAsync">
                        @for (int y = DateTime.Now.Year + 1; y >= 2020; y--)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Başlangıç Ay</label>
                    <select class="form-select form-select-sm" @bind="filtreAyBaslangic" @bind:after="LoadAsync">
                        @for (int a = 1; a <= 12; a++)
                        {
                            <option value="@a">@AyAdi(a)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Bitiş Ay</label>
                    <select class="form-select form-select-sm" @bind="filtreAyBitis" @bind:after="LoadAsync">
                        @for (int a = 1; a <= 12; a++)
                        {
                            <option value="@a">@AyAdi(a)</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Görünüm</label>
                    <select class="form-select form-select-sm" @bind="aktifSekme" @bind:after="StateHasChanged">
                        <option value="ozet">📊 Genel Özet</option>
                        <option value="aylik">📅 Aylık Karşılaştırma</option>
                        <option value="kurum">🏢 Kurum Bazlı</option>
                        <option value="tedarikci">🚛 Tedarikçi Bazlı</option>
                        <option value="arac">🚗 Araç Bazlı</option>
                    </select>
                </div>
                <div class="col-md-3 text-end">
                    <button class="btn btn-outline-primary btn-sm" @onclick="ExcelIndir" disabled="@yukleniyor">
                        <i class="bi bi-file-earmark-excel me-1"></i> Excel İndir
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (yukleniyor)
    {
        <div class="card"><div class="card-body p-4 text-center text-muted">
            <div class="spinner-border spinner-border-sm me-2"></div> Yükleniyor...
        </div></div>
    }
    else
    {
        <!-- Ana Özet Kartları -->
        <div class="row g-2 mb-3">
            <div class="col-md-3">
                <div class="card border-success shadow-sm">
                    <div class="card-body py-3">
                        <div class="text-muted small"><i class="bi bi-cash-coin me-1"></i>Toplam Gelir (Kurum)</div>
                        <div class="fs-4 fw-bold text-success">@toplamGelir.ToString("N2") ₺</div>
                        <div class="small text-muted">@toplamGelirSefer.ToString("N2") sefer</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-warning shadow-sm">
                    <div class="card-body py-3">
                        <div class="text-muted small"><i class="bi bi-truck me-1"></i>Tedarikçi Gideri</div>
                        <div class="fs-4 fw-bold text-warning">@toplamTedarikciGider.ToString("N2") ₺</div>
                        <div class="small text-muted">@tedarikciHakedisSayi hakediş</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-info shadow-sm">
                    <div class="card-body py-3">
                        <div class="text-muted small"><i class="bi bi-fuel-pump me-1"></i>Özmal/Kiralık Maliyet</div>
                        <div class="fs-4 fw-bold text-info">@toplamOzmalMaliyet.ToString("N2") ₺</div>
                        <div class="small text-muted">@snapshotSayi snapshot</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card @(NetKarZarar >= 0 ? "border-success" : "border-danger") shadow-sm">
                    <div class="card-body py-3">
                        <div class="text-muted small"><i class="bi bi-graph-up me-1"></i>Net Kar / Zarar</div>
                        <div class="fs-4 fw-bold @(NetKarZarar >= 0 ? "text-success" : "text-danger")">@NetKarZarar.ToString("N2") ₺</div>
                        <div class="small text-muted">Marj: %@MarjYuzde.ToString("N1")</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sekme İçerikleri -->
        @if (aktifSekme == "ozet")
        {
            <div class="row g-2">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header bg-light"><strong>Sahipliğe Göre Dağılım</strong></div>
                        <div class="card-body p-0">
                            <table class="table table-sm mb-0">
                                <thead class="table-light">
                                    <tr><th>Sahiplik</th><th class="text-end">Sefer</th><th class="text-end">Gelir</th><th class="text-end">Gider/Maliyet</th><th class="text-end">Kar/Zarar</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var s in SahiplikOzeti())
                                    {
                                        <tr>
                                            <td><span class="badge @SahiplikBadge(s.Sahiplik)">@s.Sahiplik</span></td>
                                            <td class="text-end">@s.Sefer.ToString("N2")</td>
                                            <td class="text-end text-success">@s.Gelir.ToString("N2")</td>
                                            <td class="text-end text-warning">@s.Gider.ToString("N2")</td>
                                            <td class="text-end fw-bold @(s.KarZarar >= 0 ? "text-success" : "text-danger")">@s.KarZarar.ToString("N2")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header bg-light"><strong>Hakediş Durum Dağılımı</strong></div>
                        <div class="card-body p-0">
                            <table class="table table-sm mb-0">
                                <thead class="table-light">
                                    <tr><th>Tip</th><th>Durum</th><th class="text-end">Adet</th><th class="text-end">Tutar</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var d in HakedisDurumOzeti())
                                    {
                                        <tr>
                                            <td><span class="badge @TipBadge(d.Tip)">@d.Tip</span></td>
                                            <td><span class="badge @DurumBadge(d.Durum)">@d.Durum</span></td>
                                            <td class="text-end">@d.Adet</td>
                                            <td class="text-end">@d.Tutar.ToString("N2") ₺</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (aktifSekme == "aylik")
        {
            <div class="card">
                <div class="card-header bg-light"><strong>Aylık Karşılaştırma — @filtreYil</strong></div>
                <div class="card-body p-0">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Ay</th>
                                <th class="text-end">Gelir Sefer</th>
                                <th class="text-end">Gelir ₺</th>
                                <th class="text-end">Tedarikçi Gider ₺</th>
                                <th class="text-end">Özmal Maliyet ₺</th>
                                <th class="text-end">Toplam Gider ₺</th>
                                <th class="text-end fw-bold">Kar/Zarar ₺</th>
                                <th class="text-end">Marj %</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in AylikOzet())
                            {
                                <tr>
                                    <td><strong>@AyAdi(a.Ay)</strong></td>
                                    <td class="text-end">@a.Sefer.ToString("N2")</td>
                                    <td class="text-end text-success">@a.Gelir.ToString("N2")</td>
                                    <td class="text-end text-warning">@a.TedarikciGider.ToString("N2")</td>
                                    <td class="text-end text-info">@a.OzmalMaliyet.ToString("N2")</td>
                                    <td class="text-end">@a.ToplamGider.ToString("N2")</td>
                                    <td class="text-end fw-bold @(a.KarZarar >= 0 ? "text-success" : "text-danger")">@a.KarZarar.ToString("N2")</td>
                                    <td class="text-end @(a.Marj >= 0 ? "text-success" : "text-danger")">%@a.Marj.ToString("N1")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr class="fw-bold">
                                <td>TOPLAM</td>
                                <td class="text-end">@AylikOzet().Sum(x => x.Sefer).ToString("N2")</td>
                                <td class="text-end text-success">@AylikOzet().Sum(x => x.Gelir).ToString("N2")</td>
                                <td class="text-end text-warning">@AylikOzet().Sum(x => x.TedarikciGider).ToString("N2")</td>
                                <td class="text-end text-info">@AylikOzet().Sum(x => x.OzmalMaliyet).ToString("N2")</td>
                                <td class="text-end">@AylikOzet().Sum(x => x.ToplamGider).ToString("N2")</td>
                                <td class="text-end @(NetKarZarar >= 0 ? "text-success" : "text-danger")">@NetKarZarar.ToString("N2")</td>
                                <td class="text-end">%@MarjYuzde.ToString("N1")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        }
        else if (aktifSekme == "kurum")
        {
            <div class="card">
                <div class="card-header bg-light"><strong>Kurum Bazlı Gelir</strong></div>
                <div class="card-body p-0">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-light">
                            <tr><th>Kurum</th><th class="text-end">Sefer</th><th class="text-end">Hakediş Adet</th><th class="text-end">Toplam Gelir ₺</th><th class="text-end">Ortalama Birim ₺</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var k in KurumOzet())
                            {
                                <tr>
                                    <td><strong>@k.Ad</strong></td>
                                    <td class="text-end">@k.Sefer.ToString("N2")</td>
                                    <td class="text-end">@k.HakedisAdet</td>
                                    <td class="text-end fw-bold text-success">@k.Tutar.ToString("N2")</td>
                                    <td class="text-end">@(k.Sefer > 0 ? (k.Tutar / k.Sefer).ToString("N2") : "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else if (aktifSekme == "tedarikci")
        {
            <div class="card">
                <div class="card-header bg-light"><strong>Tedarikçi Bazlı Gider</strong></div>
                <div class="card-body p-0">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-light">
                            <tr><th>Tedarikçi</th><th class="text-end">Sefer</th><th class="text-end">Hakediş Adet</th><th class="text-end">Toplam Gider ₺</th><th class="text-end">Ortalama Birim ₺</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var t in TedarikciOzet())
                            {
                                <tr>
                                    <td><strong>@t.Ad</strong></td>
                                    <td class="text-end">@t.Sefer.ToString("N2")</td>
                                    <td class="text-end">@t.HakedisAdet</td>
                                    <td class="text-end fw-bold text-warning">@t.Tutar.ToString("N2")</td>
                                    <td class="text-end">@(t.Sefer > 0 ? (t.Tutar / t.Sefer).ToString("N2") : "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else if (aktifSekme == "arac")
        {
            <div class="card">
                <div class="card-header bg-light"><strong>Araç Bazlı Karlılık</strong></div>
                <div class="card-body p-0">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Plaka</th>
                                <th>Sahiplik</th>
                                <th class="text-end">Sefer</th>
                                <th class="text-end">Gelir ₺</th>
                                <th class="text-end">Maliyet ₺</th>
                                <th class="text-end">Sefer/₺</th>
                                <th class="text-end fw-bold">Kar/Zarar ₺</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in AracOzet())
                            {
                                <tr>
                                    <td><strong>@a.Plaka</strong></td>
                                    <td><span class="badge @SahiplikBadge(a.Sahiplik)">@a.Sahiplik</span></td>
                                    <td class="text-end">@a.Sefer.ToString("N2")</td>
                                    <td class="text-end text-success">@a.Gelir.ToString("N2")</td>
                                    <td class="text-end text-warning">@a.Maliyet.ToString("N2")</td>
                                    <td class="text-end">@(a.Sefer > 0 ? (a.Maliyet / a.Sefer).ToString("N2") : "-")</td>
                                    <td class="text-end fw-bold @(a.KarZarar >= 0 ? "text-success" : "text-danger")">@a.KarZarar.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</div>

@code {
    private bool yukleniyor = true;

    private int filtreYil = DateTime.Now.Year;
    private int filtreAyBaslangic = 1;
    private int filtreAyBitis = 12;
    private string aktifSekme = "ozet";

    private List<Hakedis> hakedisler = new();
    private List<AracMaliyetSnapshot> snapshotlar = new();
    private List<FiloGunlukPuantaj> puantajlar = new();
    private List<Firma> firmalar = new();
    private List<TasimaTedarikci> tedarikciler = new();
    private List<Arac> araclar = new();

    // Hesaplanmış metrikler
    private decimal toplamGelir;
    private decimal toplamGelirSefer;
    private decimal toplamTedarikciGider;
    private int tedarikciHakedisSayi;
    private decimal toplamOzmalMaliyet;
    private int snapshotSayi;

    private decimal NetKarZarar => toplamGelir - toplamTedarikciGider - toplamOzmalMaliyet;
    private decimal MarjYuzde => toplamGelir > 0 ? Math.Round((NetKarZarar / toplamGelir) * 100m, 1) : 0m;

    protected override async Task OnInitializedAsync()
    {
        firmalar = await FirmaService.GetAktifFirmalarAsync();
        tedarikciler = await TedarikciService.GetAllAsync(true);
        araclar = await AracService.GetActiveAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        yukleniyor = true;
        StateHasChanged();
        try
        {
            int ayMin = Math.Min(filtreAyBaslangic, filtreAyBitis);
            int ayMax = Math.Max(filtreAyBaslangic, filtreAyBitis);

            await using var ctx = await DbContextFactory.CreateDbContextAsync();

            hakedisler = await ctx.Hakedisler
                .Where(h => h.Yil == filtreYil && h.Ay >= ayMin && h.Ay <= ayMax && h.Durum != HakedisDurum.Iptal)
                .ToListAsync();

            snapshotlar = await ctx.AracMaliyetSnapshotlari
                .Include(s => s.Arac)
                .Where(s => s.Yil == filtreYil && s.Ay >= ayMin && s.Ay <= ayMax)
                .ToListAsync();

            var basTarih = new DateTime(filtreYil, ayMin, 1);
            var bitTarih = new DateTime(filtreYil, ayMax, DateTime.DaysInMonth(filtreYil, ayMax));
            puantajlar = await ctx.FiloGunlukPuantajlar
                .Include(p => p.Arac)
                .Where(p => p.Tarih >= basTarih && p.Tarih <= bitTarih)
                .ToListAsync();

            // Toplam metrikler
            var kurumH = hakedisler.Where(h => h.Tip == HakedisTipi.Kurum).ToList();
            toplamGelir = kurumH.Sum(h => h.Tutar);
            toplamGelirSefer = kurumH.Sum(h => h.ToplamSeferSayisi);

            var tedH = hakedisler.Where(h => h.Tip == HakedisTipi.Tedarikci).ToList();
            toplamTedarikciGider = tedH.Sum(h => h.Tutar);
            tedarikciHakedisSayi = tedH.Count;

            toplamOzmalMaliyet = snapshotlar.Sum(s => s.ToplamMaliyet);
            snapshotSayi = snapshotlar.Count;
        }
        finally { yukleniyor = false; }
    }

    private record SahiplikRow(AracSahiplikTipi Sahiplik, decimal Sefer, decimal Gelir, decimal Gider, decimal KarZarar);
    private List<SahiplikRow> SahiplikOzeti()
    {
        return puantajlar
            .Where(p => p.Arac != null)
            .GroupBy(p => p.Arac!.SahiplikTipi)
            .Select(g => new SahiplikRow(
                g.Key,
                g.Sum(x => x.SeferSayisi),
                g.Sum(x => x.TahakkukEdenKurumUcreti),
                g.Sum(x => g.Key == AracSahiplikTipi.Tedarikci ? x.TahakkukEdenTaseronUcreti : (x.MaliyetOzmalKiralik ?? 0)),
                g.Sum(x => x.TahakkukEdenKurumUcreti) - g.Sum(x => g.Key == AracSahiplikTipi.Tedarikci ? x.TahakkukEdenTaseronUcreti : (x.MaliyetOzmalKiralik ?? 0))
            ))
            .OrderBy(x => x.Sahiplik)
            .ToList();
    }

    private record HakedisDurumRow(HakedisTipi Tip, HakedisDurum Durum, int Adet, decimal Tutar);
    private List<HakedisDurumRow> HakedisDurumOzeti()
    {
        return hakedisler
            .GroupBy(h => new { h.Tip, h.Durum })
            .Select(g => new HakedisDurumRow(g.Key.Tip, g.Key.Durum, g.Count(), g.Sum(x => x.Tutar)))
            .OrderBy(x => x.Tip).ThenBy(x => x.Durum)
            .ToList();
    }

    private record AylikRow(int Ay, decimal Sefer, decimal Gelir, decimal TedarikciGider, decimal OzmalMaliyet, decimal ToplamGider, decimal KarZarar, decimal Marj);
    private List<AylikRow> AylikOzet()
    {
        var liste = new List<AylikRow>();
        int ayMin = Math.Min(filtreAyBaslangic, filtreAyBitis);
        int ayMax = Math.Max(filtreAyBaslangic, filtreAyBitis);
        for (int ay = ayMin; ay <= ayMax; ay++)
        {
            var gelir = hakedisler.Where(h => h.Ay == ay && h.Tip == HakedisTipi.Kurum).Sum(h => h.Tutar);
            var sefer = hakedisler.Where(h => h.Ay == ay && h.Tip == HakedisTipi.Kurum).Sum(h => h.ToplamSeferSayisi);
            var tedGider = hakedisler.Where(h => h.Ay == ay && h.Tip == HakedisTipi.Tedarikci).Sum(h => h.Tutar);
            var ozMal = snapshotlar.Where(s => s.Ay == ay).Sum(s => s.ToplamMaliyet);
            var topGider = tedGider + ozMal;
            var kz = gelir - topGider;
            var marj = gelir > 0 ? Math.Round((kz / gelir) * 100m, 1) : 0m;
            liste.Add(new AylikRow(ay, sefer, gelir, tedGider, ozMal, topGider, kz, marj));
        }
        return liste;
    }

    private record KurumRow(string Ad, decimal Sefer, int HakedisAdet, decimal Tutar);
    private List<KurumRow> KurumOzet()
    {
        return hakedisler
            .Where(h => h.Tip == HakedisTipi.Kurum)
            .GroupBy(h => h.ReferansId)
            .Select(g => new KurumRow(
                firmalar.FirstOrDefault(f => f.Id == g.Key)?.FirmaAdi ?? $"#{g.Key}",
                g.Sum(x => x.ToplamSeferSayisi),
                g.Count(),
                g.Sum(x => x.Tutar)
            ))
            .OrderByDescending(x => x.Tutar)
            .ToList();
    }

    private record TedarikciRow(string Ad, decimal Sefer, int HakedisAdet, decimal Tutar);
    private List<TedarikciRow> TedarikciOzet()
    {
        return hakedisler
            .Where(h => h.Tip == HakedisTipi.Tedarikci)
            .GroupBy(h => h.ReferansId)
            .Select(g => new TedarikciRow(
                tedarikciler.FirstOrDefault(t => t.Id == g.Key)?.Unvan ?? $"#{g.Key}",
                g.Sum(x => x.ToplamSeferSayisi),
                g.Count(),
                g.Sum(x => x.Tutar)
            ))
            .OrderByDescending(x => x.Tutar)
            .ToList();
    }

    private record AracRow(string Plaka, AracSahiplikTipi Sahiplik, decimal Sefer, decimal Gelir, decimal Maliyet, decimal KarZarar);
    private List<AracRow> AracOzet()
    {
        // Araç bazlı: puantajdan gelir, snapshot'tan maliyet (tedarikçi araçta puantajdaki taşeron ücreti)
        var puantajGruplari = puantajlar
            .Where(p => p.Arac != null)
            .GroupBy(p => p.AracId)
            .ToDictionary(g => g.Key, g => new
            {
                Sefer = g.Sum(x => x.SeferSayisi),
                Gelir = g.Sum(x => x.TahakkukEdenKurumUcreti),
                TedarikciGider = g.Sum(x => x.TahakkukEdenTaseronUcreti),
                Arac = g.First().Arac!
            });

        var snapshotGruplari = snapshotlar
            .GroupBy(s => s.AracId)
            .ToDictionary(g => g.Key, g => g.Sum(x => x.ToplamMaliyet));

        var aracIdler = puantajGruplari.Keys.Union(snapshotGruplari.Keys).ToList();
        var liste = new List<AracRow>();
        foreach (var id in aracIdler)
        {
            var arac = araclar.FirstOrDefault(a => a.Id == id);
            if (arac == null) continue;

            var p = puantajGruplari.TryGetValue(id, out var pv) ? pv : null;
            var snapMaliyet = snapshotGruplari.TryGetValue(id, out var sm) ? sm : 0m;
            var maliyet = arac.SahiplikTipi == AracSahiplikTipi.Tedarikci ? (p?.TedarikciGider ?? 0) : snapMaliyet;
            var sefer = p?.Sefer ?? 0;
            var gelir = p?.Gelir ?? 0;
            liste.Add(new AracRow(arac.Plaka, arac.SahiplikTipi, sefer, gelir, maliyet, gelir - maliyet));
        }
        return liste.OrderByDescending(x => x.KarZarar).ToList();
    }

    private void ExcelIndir()
    {
        ToastService.ShowInfo("Excel export ileride eklenecek.");
    }

    private static string AyAdi(int a) => a switch
    {
        1 => "Ocak", 2 => "Şubat", 3 => "Mart", 4 => "Nisan",
        5 => "Mayıs", 6 => "Haziran", 7 => "Temmuz", 8 => "Ağustos",
        9 => "Eylül", 10 => "Ekim", 11 => "Kasım", 12 => "Aralık",
        _ => a.ToString()
    };

