                                </tr>
                                <tr>
                                    <td>770 - Genel Yönetim Giderleri</td>
                                    <td class="text-end">@FormatPara(gelirGiderRapor?.Giderler.Where(x => x.HesapKodu.StartsWith("770")).Sum(x => x.Tutar) ?? 0)</td>
                                    <td class="text-end fw-bold">@(gelirGiderRapor?.ToplamGider > 0 ? ((gelirGiderRapor.Giderler.Where(x => x.HesapKodu.StartsWith("770")).Sum(x => x.Tutar) / gelirGiderRapor.ToplamGider) * 100).ToString("N2") : "0.00")%</td>
                                </tr>
                                <tr>
                                    <td>780 - Finansman Giderleri</td>
                                    <td class="text-end">@FormatPara(gelirGiderRapor?.Giderler.Where(x => x.HesapKodu.StartsWith("780")).Sum(x => x.Tutar) ?? 0)</td>
                                    <td class="text-end fw-bold">@(gelirGiderRapor?.ToplamGider > 0 ? ((gelirGiderRapor.Giderler.Where(x => x.HesapKodu.StartsWith("780")).Sum(x => x.Tutar) / gelirGiderRapor.ToplamGider) * 100).ToString("N2") : "0.00")%</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
