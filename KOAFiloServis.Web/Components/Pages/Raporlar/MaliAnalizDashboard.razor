                                    else { <span class="badge bg-secondary rounded-pill">Ortalama (%@dashboard.KarlilikOrani.ToString("N1"))</span> }
                                </li>
                                <li class="list-group-item">Geniş Müşteri Ağı ve Kiralık Araç Filosu.</li>
                                <li class="list-group-item">Sabit Gelirli Komisyon İşlemleri.</li>
                            </ul>
                            <div class="mt-3">
                                <textarea class="form-control" rows="2" placeholder="Yeni güçlü yön analizi yazın..."></textarea>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card h-100 border-danger shadow-sm">
                        <div class="card-header bg-danger text-white">
                            <h5 class="mb-0"><i class="bi bi-arrow-down-circle me-2"></i>Zayıf Yönler (Weaknesses)</h5>
                        </div>
                        <div class="card-body">
                            <ul class="list-group list-group-flush">
                                @if(dashboard.OzmalAracAnaliz.Kar < 0) {
                                    <li class="list-group-item text-danger">Özmal Araçlar Zararda (@FormatPara(dashboard.OzmalAracAnaliz.Kar))</li>
                                }
                                @if(dashboard.KiralikAracAnaliz.Kar < 0) {
                                    <li class="list-group-item text-danger">Kiralık Araçlar Zararda (@FormatPara(dashboard.KiralikAracAnaliz.Kar))</li>
                                }
                                <li class="list-group-item">Artan yakıt ve bakım maliyetleri oranları.</li>
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    Gider/Gelir Oranı
                                    @if (dashboard.ToplamGelir > 0)
                                    {
                                        <span class="badge bg-danger rounded-pill">%(Math.Round((dashboard.ToplamGider / dashboard.ToplamGelir)*100,1))</span>
                                    }
                                </li>
                            </ul>
                            <div class="mt-3">
                                <textarea class="form-control" rows="2" placeholder="Yeni zayıf yön analizi yazın..."></textarea>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card h-100 border-info shadow-sm">
                        <div class="card-header bg-info text-white">
                            <h5 class="mb-0"><i class="bi bi-lightbulb me-2"></i>Fırsatlar (Opportunities)</h5>
                        </div>
                        <div class="card-body">
                            <ul class="list-group list-group-flush">
                                <li class="list-group-item">En Karlı Güzergahları Büyütme: <strong>@(dashboard.EnKarliGuzergahlar.FirstOrDefault()?.Etiket ?? "Belirsiz")</strong></li>
                                <li class="list-group-item">Araç sayısını optimize ederek marjı artırma potansiyeli.</li>
                                <li class="list-group-item">Yeni lojistik anlaşmaları ve müşteri segmentleri.</li>
                            </ul>
                            <div class="mt-3">
                                <textarea class="form-control" rows="2" placeholder="Yeni fırsat analizi yazın..."></textarea>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card h-100 border-warning shadow-sm">
                        <div class="card-header bg-warning text-dark">
                            <h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Tehditler (Threats)</h5>
                        </div>
                        <div class="card-body">
                            <ul class="list-group list-group-flush">
                                <li class="list-group-item">
                                    En Yüksek Gider Kalemi: <strong>@(dashboard.GiderDagilimi.OrderByDescending(x=>x.Deger).FirstOrDefault()?.Etiket ?? "Belirsiz")</strong> maliyetlerinde artış.
                                </li>
                                <li class="list-group-item">Sektörel enflasyon ve bölgesel yakıt fiyatları dengesizliği.</li>
                                <li class="list-group-item">Araç arızaları kaynaklı sefer iptalleri ve gecikme cezaları.</li>
                            </ul>
                            <div class="mt-3">
                                <textarea class="form-control" rows="2" placeholder="Yeni tehdit analizi yazın..."></textarea>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="mt-3 text-end d-print-none">
                <button class="btn btn-primary" onclick="window.print()"><i class="bi bi-printer me-1"></i> SWOT Raporunu Yazdır</button>
            </div>
        }
        else if (aktifSekme == "trend")
        {
            <div class="row mb-4 g-3">
                <div class="col-md-3">
                    <div class="card bg-primary text-white h-100">
                        <div class="card-body text-center">
                            <small>@secilenYil Net Kar</small>
                            <h4 class="mb-0">@FormatPara(SeciliYilToplamNetKar)</h4>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-secondary text-white h-100">
                        <div class="card-body text-center">
                            <small>@(secilenYil - 1) Net Kar</small>
                            <h4 class="mb-0">@FormatPara(OncekiYilToplamNetKar)</h4>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card @(YillikNetKarFarki >= 0 ? "bg-success" : "bg-danger") text-white h-100">
                        <div class="card-body text-center">
                            <small>Yıllık Fark</small>
                            <h4 class="mb-0">@FormatPara(YillikNetKarFarki)</h4>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-info text-white h-100">
                        <div class="card-body text-center">
                            <small>Değişim Oranı</small>
                            <h4 class="mb-0">%@YillikNetKarDegisimOrani.ToString("N1")</h4>
                        </div>
                    </div>
                </div>
            </div>

            @if (secilenAy > 0 && dashboard != null && trendAyniAyGecenYil != null)
            {
                <div class="card mb-4">
                    <div class="card-header">
                        <h6 class="mb-0"><i class="bi bi-calendar-range me-2"></i>Aynı Ay Karşılaştırması - @GetAyAdi(secilenAy)</h6>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <div class="border rounded p-3 h-100">
                                    <small class="text-muted">@secilenYil</small>
                                    <h5 class="text-primary mb-1">@FormatPara(dashboard.NetKar)</h5>
                                    <div class="small text-muted">Gelir: @FormatPara(dashboard.ToplamGelir)</div>
                                    <div class="small text-muted">Gider: @FormatPara(dashboard.ToplamGider)</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="border rounded p-3 h-100">
                                    <small class="text-muted">@(secilenYil - 1)</small>
                                    <h5 class="text-secondary mb-1">@FormatPara(trendAyniAyGecenYil.NetKar)</h5>
                                    <div class="small text-muted">Gelir: @FormatPara(trendAyniAyGecenYil.ToplamGelir)</div>
                                    <div class="small text-muted">Gider: @FormatPara(trendAyniAyGecenYil.ToplamGider)</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="border rounded p-3 h-100">
                                    <small class="text-muted">Fark</small>
                                    <h5 class="@(AyniAyNetKarFarki >= 0 ? "text-success" : "text-danger") mb-1">@FormatPara(AyniAyNetKarFarki)</h5>
                                    <div class="small text-muted">Değişim: %@AyniAyNetKarDegisimOrani.ToString("N1")</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="card mb-4">
                <div class="card-header">
                    <h6 class="mb-0"><i class="bi bi-table me-2"></i>Aylık Karşılaştırma Tablosu (@secilenYil / @(secilenYil - 1))</h6>
                </div>
                <div class="card-body p-0">
                    @if (trendSeciliYil.Any() || trendOncekiYil.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0 align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Ay</th>
                                        <th class="text-end">@secilenYil Net</th>
                                        <th class="text-end">@(secilenYil - 1) Net</th>
                                        <th class="text-end">Fark</th>
                                        <th class="text-end">Değişim %</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var satir in GetTrendKarsilastirmaSatirlari())
                                    {
                                        <tr>
                                            <td>@satir.AyEtiketi</td>
                                            <td class="text-end">@FormatPara(satir.BuYilNetKar)</td>
                                            <td class="text-end text-muted">@FormatPara(satir.GecenYilNetKar)</td>
                                            <td class="text-end @(satir.Fark >= 0 ? "text-success" : "text-danger") fw-bold">@FormatPara(satir.Fark)</td>
                                            <td class="text-end">%@satir.DegisimOrani.ToString("N1")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <p>Karşılaştırma verisi bulunmuyor</p>
                        </div>
                    }
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h6 class="mb-0"><i class="bi bi-graph-up me-2"></i>@secilenYil Yıllık Kar Trendi</h6>
                </div>
                <div class="card-body">
                    @if (trendSeciliYil.Any())
                    {
                        var maxDeger = trendSeciliYil.Max(x => Math.Abs(x.Deger));

                        <div class="d-flex align-items-end justify-content-between" style="height: 200px;">
                            @foreach (var item in trendSeciliYil)
                            {
                                var yukseklik = maxDeger > 0 ? (double)(Math.Abs(item.Deger) / maxDeger) * 100 : 0;
                                var renk = item.Deger >= 0 ? "bg-success" : "bg-danger";

                                <div class="text-center flex-fill px-1">
                                    <div class="d-flex flex-column align-items-center">
                                        <small class="@(item.Deger >= 0 ? "text-success" : "text-danger")">
                                            @(item.Deger >= 0 ? "" : "-")@Math.Abs(item.Deger).ToString("N0")
                                        </small>
                                        <div style="width: 80%; height: @(yukseklik * 1.5)px; min-height: 10px;"
                                             class="@renk rounded-top mt-1"
                                             title="@item.EkBilgi">
                                        </div>
                                    </div>
                                    <small class="text-muted">@item.Etiket</small>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <p>Yıllık trend verisi bulunmuyor</p>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

@code {
    private int secilenYil = DateTime.Today.Year;
    private int secilenAy = DateTime.Today.Month;
    private Models.MaliAnalizDashboard? dashboard;
    private Models.MaliAnalizDashboard? trendAyniAyGecenYil;
    private GelirGiderRapor? gelirGiderRapor;
    private BilancoRapor? bilancoRapor;
    private List<Models.GrafikVeri> trendSeciliYil = new();
    private List<Models.GrafikVeri> trendOncekiYil = new();
    private List<BudgetOdeme> bekleyenTedarikciHakedisleri = new();
    private List<BudgetOdeme> tumTedarikciHakedisleri = new();
    private const string TasimaTedarikciHakedisKalemi = "Taşıma Tedarikçi Hakediş";
    private bool isLoading = false;
    
    private string aktifSekme = "genel";

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task YenileData()
    {
        await LoadDataAsync();
    }
    
    private async Task SekmeDegistir(string sekme)
    {
        aktifSekme = sekme;
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        try
        {
            if (aktifSekme == "genel")
            {
                dashboard = await MaliAnalizService.GetDashboardAsync(secilenYil, secilenAy > 0 ? secilenAy : DateTime.Today.Month);
                await LoadBekleyenTedarikciHakedisleriAsync();
            }
            if (aktifSekme == "trend")
            {
                trendSeciliYil = await MaliAnalizService.GetYillikTrendAsync(secilenYil);
                trendOncekiYil = await MaliAnalizService.GetYillikTrendAsync(secilenYil - 1);

                if (secilenAy > 0)
                {
                    dashboard = await MaliAnalizService.GetDashboardAsync(secilenYil, secilenAy);
                    trendAyniAyGecenYil = await MaliAnalizService.GetDashboardAsync(secilenYil - 1, secilenAy);
                }
                else
                {
                    dashboard = null;
                    trendAyniAyGecenYil = null;
                }
            }
            if (aktifSekme == "dupont" || aktifSekme == "dikeyyatay" || aktifSekme == "nakitakis")
            {
                gelirGiderRapor = await MuhasebeService.GetGelirGiderRaporuAsync(secilenYil, secilenAy > 0 ? secilenAy : null);
            }
            if (aktifSekme == "dupont" || aktifSekme == "dikeyyatay")
            {
                var tarih = secilenAy > 0 
                  ? new DateTime(secilenYil, secilenAy, DateTime.DaysInMonth(secilenYil, secilenAy)) 
                  : new DateTime(secilenYil, 12, 31);
                bilancoRapor = await MuhasebeService.GetBilancoRaporuAsync(tarih);
            }
            if (aktifSekme == "dupont")
            {
                HesaplaRasyo();
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadBekleyenTedarikciHakedisleriAsync()
    {
        try
        {
            // Tüm yıl için (filtreden bağımsız) bekleyen tedarikçi hakedişlerini getir
            var tumOdemeler = await BudgetService.GetOdemelerAsync(secilenYil, null);
            tumTedarikciHakedisleri = tumOdemeler
                .Where(o => string.Equals(o.MasrafKalemi, TasimaTedarikciHakedisKalemi, StringComparison.OrdinalIgnoreCase))
                .ToList();
            bekleyenTedarikciHakedisleri = tumTedarikciHakedisleri
                .Where(o => o.Durum == OdemeDurum.Bekliyor || o.Durum == OdemeDurum.KismiOdendi)
                .ToList();
        }
        catch
        {
            bekleyenTedarikciHakedisleri = new();
            tumTedarikciHakedisleri = new();
        }
    }

    private void OdemeYonetimineGit(int odemeId)
    {
        Navigation.NavigateTo($"/butce/odemeler?odemeId={odemeId}");
    }

    private decimal NetKarMarji = 0;
    private decimal AktifDevirHizi = 0;
    private decimal OzkaynakCarpani = 0;
    private decimal CariOran = 0;
    private decimal AsitTestOrani = 0;
    private decimal NakitOrani = 0;
    private decimal DisKaynakOrani = 0;
    private decimal KisaVadeliBorcOrani = 0;

    private void HesaplaRasyo()
    {
        if (gelirGiderRapor == null || bilancoRapor == null) return;
        
        decimal satislar = gelirGiderRapor.ToplamGelir > 0 ? gelirGiderRapor.ToplamGelir : 1m;
        decimal netKar = gelirGiderRapor.NetKar;
        
        decimal toplamAktif = bilancoRapor.ToplamAktif > 0 ? bilancoRapor.ToplamAktif : 1m;
        decimal ozkaynak = bilancoRapor.Ozkaynaklar.Sum(o => o.Tutar);
        if (ozkaynak <= 0) ozkaynak = 1m;

        decimal donenVarliklar = bilancoRapor.DonenVarliklar.Sum(k => k.Tutar);
        decimal kisaVadeliBorclar = bilancoRapor.KisaVadeliYabanciKaynaklar.Sum(k => k.Tutar);
        if (kisaVadeliBorclar <= 0) kisaVadeliBorclar = 1m;

        NetKarMarji = (netKar / satislar) * 100;
        AktifDevirHizi = satislar / toplamAktif;
        OzkaynakCarpani = toplamAktif / ozkaynak;

        CariOran = donenVarliklar / kisaVadeliBorclar;
        
        decimal stoklar = bilancoRapor.DonenVarliklar.FirstOrDefault(k => k.HesapKodu == "153")?.Tutar ?? 0;
        AsitTestOrani = (donenVarliklar - stoklar) / kisaVadeliBorclar;
        
        decimal hazirDegerler = bilancoRapor.DonenVarliklar.Where(k => k.HesapKodu.StartsWith("100") || k.HesapKodu.StartsWith("102")).Sum(k => k.Tutar);
        NakitOrani = hazirDegerler / kisaVadeliBorclar;

        DisKaynakOrani = bilancoRapor.ToplamPasif > 0 ? ((bilancoRapor.KisaVadeliYabanciKaynaklar.Sum(x=>x.Tutar) + bilancoRapor.UzunVadeliYabanciKaynaklar.Sum(x=>x.Tutar)) / bilancoRapor.ToplamPasif) : 0;
        KisaVadeliBorcOrani = bilancoRapor.ToplamPasif > 0 ? (kisaVadeliBorclar / bilancoRapor.ToplamPasif) : 0;
    }

    private decimal SeciliYilToplamNetKar => trendSeciliYil.Sum(x => x.Deger);
    private decimal OncekiYilToplamNetKar => trendOncekiYil.Sum(x => x.Deger);
    private decimal YillikNetKarFarki => SeciliYilToplamNetKar - OncekiYilToplamNetKar;
    private decimal YillikNetKarDegisimOrani => OncekiYilToplamNetKar != 0 ? (YillikNetKarFarki / Math.Abs(OncekiYilToplamNetKar)) * 100 : 0;
    private decimal AyniAyNetKarFarki => (dashboard?.NetKar ?? 0) - (trendAyniAyGecenYil?.NetKar ?? 0);
    private decimal AyniAyNetKarDegisimOrani => trendAyniAyGecenYil?.NetKar is not null and not 0
        ? (AyniAyNetKarFarki / Math.Abs(trendAyniAyGecenYil.NetKar)) * 100
        : 0;

    private async Task ExportCsvAsync()
    {
        try
        {
            var rows = GetExportRows();
            var bytes = DataExportService.ExportToCsv(rows);
            await JS.InvokeVoidAsync("downloadFileFromBytes", GetExportFileName("csv"), "text/csv", bytes);
            ToastService.ShowSuccess("CSV dışa aktarımı tamamlandı.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"CSV export hatası: {ex.Message}");
        }
    }

    private async Task ExportJsonAsync()
    {
        try
        {
            var payload = new
            {
                Sekme = aktifSekme,
                Yil = secilenYil,
                Ay = secilenAy,
                OlusturulmaTarihi = DateTime.UtcNow,
                Veriler = GetExportRows()
            };

            var bytes = DataExportService.ExportToJson(payload);
            await JS.InvokeVoidAsync("downloadFileFromBytes", GetExportFileName("json"), "application/json", bytes);
            ToastService.ShowSuccess("JSON dışa aktarımı tamamlandı.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"JSON export hatası: {ex.Message}");
        }
    }

    private List<TrendKarsilastirmaSatiri> GetTrendKarsilastirmaSatirlari()
    {
        var aylar = Enumerable.Range(1, 12)
            .Select(i => new DateTime(secilenYil, i, 1).ToString("MMM"))
            .ToList();

        return aylar.Select(ay =>
        {
            var buYil = trendSeciliYil.FirstOrDefault(x => x.Etiket == ay)?.Deger ?? 0;
            var gecenYil = trendOncekiYil.FirstOrDefault(x => x.Etiket == ay)?.Deger ?? 0;
            var fark = buYil - gecenYil;
            var degisim = gecenYil != 0 ? (fark / Math.Abs(gecenYil)) * 100 : 0;

            return new TrendKarsilastirmaSatiri
            {
                AyEtiketi = ay,
                BuYilNetKar = buYil,
                GecenYilNetKar = gecenYil,
                Fark = fark,
                DegisimOrani = degisim
            };
        }).ToList();
    }

    private List<MaliAnalizExportSatiri> GetExportRows()
    {
        var rows = new List<MaliAnalizExportSatiri>();

        switch (aktifSekme)
        {
            case "genel" when dashboard != null:
                rows.AddRange(new[]
                {
                    new MaliAnalizExportSatiri { Sekme = "Genel", Grup = "Özet", Etiket = "Toplam Gelir", Deger = dashboard.ToplamGelir },
                    new MaliAnalizExportSatiri { Sekme = "Genel", Grup = "Özet", Etiket = "Toplam Gider", Deger = dashboard.ToplamGider },
                    new MaliAnalizExportSatiri { Sekme = "Genel", Grup = "Özet", Etiket = "Net Kar", Deger = dashboard.NetKar },
                    new MaliAnalizExportSatiri { Sekme = "Genel", Grup = "Özet", Etiket = "Karlılık Oranı", Deger = dashboard.KarlilikOrani }
                });

                rows.Add(CreateSegmentRow("Genel", "Segment", "Özmal", dashboard.OzmalAracAnaliz.Gelir, dashboard.OzmalAracAnaliz.Gider));
                rows.Add(CreateSegmentRow("Genel", "Segment", "Kiralık", dashboard.KiralikAracAnaliz.Gelir, dashboard.KiralikAracAnaliz.Gider));
                rows.Add(CreateSegmentRow("Genel", "Segment", "Komisyon", dashboard.KomisyonAnaliz.Gelir, dashboard.KomisyonAnaliz.Gider));
                break;

            case "trend":
                rows.AddRange(GetTrendKarsilastirmaSatirlari().Select(x => new MaliAnalizExportSatiri
                {
                    Sekme = "Trend",
                    Grup = "Yıllık Karşılaştırma",
                    Etiket = x.AyEtiketi,
                    Deger = x.BuYilNetKar,
                    KarsilastirmaDegeri = x.GecenYilNetKar,
                    Fark = x.Fark,
                    Oran = x.DegisimOrani
                }));
                break;

            case "dupont":
                rows.AddRange(new[]
                {
                    new MaliAnalizExportSatiri { Sekme = "DuPont", Grup = "Rasyo", Etiket = "Net Kar Marjı", Deger = NetKarMarji },
                    new MaliAnalizExportSatiri { Sekme = "DuPont", Grup = "Rasyo", Etiket = "Aktif Devir Hızı", Deger = AktifDevirHizi },
                    new MaliAnalizExportSatiri { Sekme = "DuPont", Grup = "Rasyo", Etiket = "Özkaynak Çarpanı", Deger = OzkaynakCarpani },
                    new MaliAnalizExportSatiri { Sekme = "DuPont", Grup = "Likidite", Etiket = "Cari Oran", Deger = CariOran },
                    new MaliAnalizExportSatiri { Sekme = "DuPont", Grup = "Likidite", Etiket = "Asit Test Oranı", Deger = AsitTestOrani },
                    new MaliAnalizExportSatiri { Sekme = "DuPont", Grup = "Likidite", Etiket = "Nakit Oranı", Deger = NakitOrani }
                });
                break;

            default:
                if (gelirGiderRapor != null)
                {
                    rows.AddRange(gelirGiderRapor.Gelirler.Select(x => new MaliAnalizExportSatiri
                    {
                        Sekme = aktifSekme,
                        Grup = "Gelir",
                        Etiket = x.HesapAdi,
                        Deger = x.Tutar
                    }));

                    rows.AddRange(gelirGiderRapor.Giderler.Select(x => new MaliAnalizExportSatiri
                    {
                        Sekme = aktifSekme,
                        Grup = "Gider",
                        Etiket = x.HesapAdi,
                        Deger = x.Tutar
                    }));
                }
                break;
        }

        if (aktifSekme == "swot")
        {
            rows.AddRange(SWOTAnalizi.Guc.Select(x => new MaliAnalizExportSatiri { Sekme = "SWOT", Grup = "Güçlü Yön", Etiket = x }));
            rows.AddRange(SWOTAnalizi.Zayif.Select(x => new MaliAnalizExportSatiri { Sekme = "SWOT", Grup = "Zayıf Yön", Etiket = x }));
            rows.AddRange(SWOTAnalizi.Firsat.Select(x => new MaliAnalizExportSatiri { Sekme = "SWOT", Grup = "Fırsat", Etiket = x }));
            rows.AddRange(SWOTAnalizi.Tehtid.Select(x => new MaliAnalizExportSatiri { Sekme = "SWOT", Grup = "Tehdit", Etiket = x }));
        }

        return rows;
    }

    private MaliAnalizExportSatiri CreateSegmentRow(string sekme, string grup, string etiket, decimal gelir, decimal gider)
    {
        return new MaliAnalizExportSatiri
        {
            Sekme = sekme,
            Grup = grup,
            Etiket = etiket,
            Deger = gelir,
            KarsilastirmaDegeri = gider,
            Fark = gelir - gider,
            Oran = gelir != 0 ? ((gelir - gider) / gelir) * 100 : 0
        };
    }

    private string GetExportFileName(string extension)
        => $"MaliAnaliz_{aktifSekme}_{secilenYil}_{(secilenAy > 0 ? secilenAy : 0):00}.{extension}";

    private string GetAyAdi(int ay) => new DateTime(secilenYil, ay, 1).ToString("MMMM");

    private string FormatPara(decimal tutar) => tutar.ToString("N0") + " TL";

