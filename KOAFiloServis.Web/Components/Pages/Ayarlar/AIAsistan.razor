@page "/ai-asistan"
@using System.Text
@using System.Text.RegularExpressions
@using KOAFiloServis.Web.Services
@using KOAFiloServis.Shared.Entities
@using Microsoft.Extensions.AI
@inject IOllamaAIChatService ChatService
@inject IDestekTalebiService DestekTalebiService
@inject IConfiguration Configuration
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>AI Asistan - CRM Filo Servis</PageTitle>

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-8">
            <!-- Header -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="mb-1">
                        <i class="bi bi-robot me-2 text-primary"></i>AI Asistan
                    </h2>
                    <small class="text-muted">Ollama ile çevrimiçi veya yerel AI sohbeti</small>
                </div>
                <div class="d-flex gap-2">
                    <!-- Model Seçimi -->
                    <div class="input-group" style="width: 240px;">
                        <span class="input-group-text"><i class="bi bi-cpu"></i></span>
                        <select class="form-select form-select-sm" @bind="selectedModel" @bind:after="OnModelChanged" disabled="@isLoading">
                            @{
                                var birlesikModeller = GetBirlesikModelListesi();
                                var yuklu = new HashSet<string>(availableModels, StringComparer.OrdinalIgnoreCase);
                            }
                            @if (birlesikModeller.Any())
                            {
                                <optgroup label="Yerel (Ollama)">
                                    @foreach (var model in birlesikModeller.Where(m => yuklu.Contains(m)))
                                    {
                                        <option value="@model">@model</option>
                                    }
                                </optgroup>
                                <optgroup label="Önerilen (yüklü değil)">
                                    @foreach (var model in birlesikModeller.Where(m => !yuklu.Contains(m)))
                                    {
                                        <option value="@model">@model (indir: ollama pull @model)</option>
                                    }
                                </optgroup>
                            }
                            else
                            {
                                <option value="@selectedModel">@selectedModel</option>
                            }
                        </select>
                    </div>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="RefreshModels" disabled="@isLoading" title="Modelleri Yenile">
                        <i class="bi bi-arrow-clockwise"></i>
                    </button>
                    <button class="btn btn-outline-danger btn-sm" @onclick="ClearChat" disabled="@isLoading" title="Sohbeti Temizle">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            </div>

            <!-- Connection Status -->
            @if (!isOllamaAvailable && connectionChecked)
            {
                <div class="alert alert-warning d-flex align-items-center" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <div>
                        <strong>Ollama bağlantısı kurulamadı!</strong>
                        <br />
                        <small>Endpoint: <code>@ollamaBaseUrl</code> · Ollama'nın çalıştığından emin olun: <code>ollama serve</code> veya <code>ollama run @selectedModel</code></small>
                    </div>
                </div>
            }

            <div class="card shadow-sm mb-3">
                <div class="card-body py-2">
                    <div class="row g-2 align-items-center">
                        <div class="col-md-7 small text-muted">
                            <i class="bi bi-hdd-network me-1"></i>
                            Endpoint: <code>@ollamaBaseUrl</code>
                            <span class="ms-2 badge @(isRemoteEndpoint ? "bg-success" : "bg-secondary")">@(isRemoteEndpoint ? "Online" : "Yerel")</span>
                        </div>
                        <div class="col-md-5">
                            <div class="form-check form-switch d-flex justify-content-md-end align-items-center mb-0">
                                <input class="form-check-input me-2" type="checkbox" id="kbToggle" @bind="useKnowledgeBase" />
                                <label class="form-check-label small" for="kbToggle">Bilgi bankası ile cevapla</label>
                            </div>
                        </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(lastKnowledgeInfo))
                    {
                        <div class="small text-muted mt-2">
                            <i class="bi bi-bookmark-star me-1"></i>@lastKnowledgeInfo
                        </div>
                    }
                </div>
            </div>

            <!-- Chat Container -->
            <div class="card shadow-sm" style="height: calc(100vh - 280px); min-height: 400px;">
                <div class="card-body d-flex flex-column p-0">
                    <!-- Messages Area -->
                    <div class="flex-grow-1 overflow-auto p-3" id="chatMessages" @ref="messagesContainer">
                        @if (!messages.Any())
                        {
                            <div class="text-center text-muted py-5">
                                <i class="bi bi-chat-dots display-1 mb-3 d-block opacity-50"></i>
                                <h5>Merhaba! Ben AI Asistanınızım</h5>
                                <p class="mb-4">Size nasıl yardımcı olabilirim?</p>
                                <div class="row g-2 justify-content-center">
                                    @foreach (var suggestion in chatSuggestions)
                                    {
                                        <div class="col-auto">
                                            <button class="btn btn-outline-primary btn-sm" @onclick="() => SendSuggestion(suggestion)">
                                                @suggestion
                                            </button>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            @foreach (var msg in messages)
                            {
                                <div class="d-flex mb-3 @(msg.IsUser ? "justify-content-end" : "justify-content-start")">
                                    <div class="d-flex @(msg.IsUser ? "flex-row-reverse" : "flex-row") gap-2" style="max-width: 80%;">
                                        <!-- Avatar -->
                                        <div class="flex-shrink-0">
                                            <div class="rounded-circle d-flex align-items-center justify-content-center @(msg.IsUser ? "bg-primary" : "bg-success")"
                                                 style="width: 36px; height: 36px;">
                                                <i class="bi @(msg.IsUser ? "bi-person" : "bi-robot") text-white"></i>
                                            </div>
                                        </div>
                                        <!-- Message Bubble -->
                                        <div class="@(msg.IsUser ? "bg-primary text-white" : "bg-light") rounded-3 p-3">
                                            <div class="message-content" style="white-space: pre-wrap;">@((MarkupString)FormatMessage(msg.Content))</div>
                                            <small class="@(msg.IsUser ? "text-white-50" : "text-muted") d-block mt-1">
                                                @msg.Timestamp.ToString("HH:mm")
                                            </small>
                                        </div>
                                    </div>
                                </div>
                            }

                            @if (isTyping)
                            {
                                <div class="d-flex justify-content-start mb-3">
                                    <div class="d-flex flex-row gap-2" style="max-width: 80%;">
                                        <div class="flex-shrink-0">
                                            <div class="rounded-circle d-flex align-items-center justify-content-center bg-success"
                                                 style="width: 36px; height: 36px;">
                                                <i class="bi bi-robot text-white"></i>
                                            </div>
                                        </div>
                                        <div class="bg-light rounded-3 p-3">
                                            @if (!string.IsNullOrEmpty(streamingContent))
                                            {
                                                <div class="message-content" style="white-space: pre-wrap;">@((MarkupString)FormatMessage(streamingContent))</div>
                                            }
                                            else
                                            {
                                                <div class="typing-indicator">
                                                    <span></span>
                                                    <span></span>
                                                    <span></span>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    <!-- Input Area -->
                    <div class="border-top p-3 bg-light">
                        <div class="input-group">
                            <textarea class="form-control"
                                      placeholder="Mesajınızı yazın..."
                                      @bind="userMessage"
                                      @bind:event="oninput"
                                      @onkeydown="HandleKeyDown"
                                      rows="1"
                                      disabled="@(isLoading || !isOllamaAvailable)"
                                      style="resize: none; max-height: 120px;"></textarea>
                            <button class="btn btn-primary px-4" @onclick="SendMessage" disabled="@(isLoading || string.IsNullOrWhiteSpace(userMessage) || !isOllamaAvailable)">
                                @if (isLoading)
                                {
                                    <span class="spinner-border spinner-border-sm"></span>
                                }
                                else
                                {
                                    <i class="bi bi-send-fill"></i>
                                }
                            </button>
                        </div>
                        <small class="text-muted mt-1 d-block">
                            <i class="bi bi-info-circle me-1"></i>
                            Model: <strong>@selectedModel</strong> | Mod: <strong>@(isRemoteEndpoint ? "Online" : "Yerel")</strong> | Enter ile gönder, Shift+Enter ile yeni satır
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .typing-indicator {
        display: flex;
        gap: 4px;
    }

        .typing-indicator span {
            width: 8px;
            height: 8px;
            background-color: #6c757d;
            border-radius: 50%;
            animation: typing 1.4s infinite ease-in-out both;
        }

            .typing-indicator span:nth-child(1) {
                animation-delay: -0.32s;
            }

            .typing-indicator span:nth-child(2) {
                animation-delay: -0.16s;
            }

    @@keyframes typing {
        0%, 80%, 100% {
            transform: scale(0.6);
            opacity: 0.5;
        }

        40% {
            transform: scale(1);
            opacity: 1;
        }
    }

    .message-content code {
        background-color: rgba(0, 0, 0, 0.1);
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 0.9em;
    }

    .message-content pre {
        background-color: #1e1e1e;
        color: #d4d4d4;
        padding: 12px;
        border-radius: 8px;
        overflow-x: auto;
        margin: 8px 0;
    }

        .message-content pre code {
            background-color: transparent;
            padding: 0;
            color: inherit;
        }

    .bg-primary .message-content code {
        background-color: rgba(255, 255, 255, 0.2);
        color: #fff;
    }
</style>

@code {
    private ElementReference messagesContainer;
    private string userMessage = "";
    private string selectedModel = "llama3.2";
    private List<string> availableModels = new();
    private List<ChatMessageDisplay> messages = new();
    private bool isLoading = false;
    private bool isTyping = false;
    private bool isOllamaAvailable = false;
    private bool connectionChecked = false;
    private string streamingContent = "";
    private CancellationTokenSource? streamingCts;
    private readonly List<ChatMessage> conversationHistory = new();
    private bool useKnowledgeBase = true;
    private string ollamaBaseUrl = string.Empty;
    private string lastKnowledgeInfo = string.Empty;

    private bool isRemoteEndpoint =>
        !ollamaBaseUrl.Contains("localhost", StringComparison.OrdinalIgnoreCase) &&
        !ollamaBaseUrl.Contains("127.0.0.1", StringComparison.OrdinalIgnoreCase);

    private readonly List<string> chatSuggestions = new()
    {
        "Bugün bana nasıl yardımcı olabilirsin?",
        "Filo yönetimi hakkında bilgi ver",
        "C# ile basit bir örnek kod yaz",
        "Araç bakım takibi nasıl yapılır?"
    };

    private List<string> GetBirlesikModelListesi()
    {
        var onTanililar = new[] { "llama3.2", "llama3", "mistral", "phi3", "gemma2", "deepseek-coder-v2" };
        var list = new HashSet<string>(availableModels, StringComparer.OrdinalIgnoreCase);
        foreach (var t in onTanililar) list.Add(t);
        return list.OrderBy(x => x).ToList();
    }

    protected override async Task OnInitializedAsync()
    {
        ollamaBaseUrl = (Configuration["Ollama:BaseUrl"] ?? "http://localhost:11434").TrimEnd('/');
        selectedModel = ChatService.CurrentModel;
        await CheckOllamaConnection();
        if (isOllamaAvailable)
        {
            await RefreshModels();
        }
    }

    private async Task CheckOllamaConnection()
    {
        isOllamaAvailable = await ChatService.IsAvailableAsync();
        connectionChecked = true;
    }

    private async Task RefreshModels()
    {
        try
        {
            availableModels = await ChatService.GetAvailableModelsAsync();
            if (availableModels.Any() && !availableModels.Contains(selectedModel))
            {
                selectedModel = availableModels.First();
                ChatService.SetModel(selectedModel);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Model listesi alınamadı: {ex.Message}");
        }
    }

    private void OnModelChanged()
    {
        ChatService.SetModel(selectedModel);
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey && !string.IsNullOrWhiteSpace(userMessage))
        {
            await SendMessage();
        }
    }

    private async Task SendSuggestion(string suggestion)
    {
        userMessage = suggestion;
        await SendMessage();
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(userMessage) || isLoading) return;

        var messageToSend = userMessage.Trim();
        userMessage = "";

        // Add user message
        messages.Add(new ChatMessageDisplay
        {
            Content = messageToSend,
            IsUser = true,
            Timestamp = DateTime.Now
        });

        isLoading = true;
        isTyping = true;
        streamingContent = "";
        StateHasChanged();
        await ScrollToBottom();

        try
        {
            streamingCts = new CancellationTokenSource();

            var aiPrompt = await BuildAssistantPromptAsync(messageToSend);

            await foreach (var chunk in ChatService.ChatWithHistoryStreamAsync(conversationHistory, aiPrompt, streamingCts.Token))
            {
                streamingContent += chunk;
                StateHasChanged();
                await ScrollToBottom();
            }

            conversationHistory.Add(new ChatMessage(ChatRole.User, messageToSend));
            conversationHistory.Add(new ChatMessage(ChatRole.Assistant, streamingContent));

            // Add assistant message
            messages.Add(new ChatMessageDisplay
            {
                Content = streamingContent,
                IsUser = false,
                Timestamp = DateTime.Now
            });
        }
        catch (OperationCanceledException)
        {
            // User cancelled
        }
        catch (Exception ex)
        {
            var hataMesaji = ex.GetBaseException().Message;

            if (hataMesaji.Contains("404", StringComparison.OrdinalIgnoreCase) ||
                hataMesaji.Contains("not found", StringComparison.OrdinalIgnoreCase) ||
                hataMesaji.Contains("model", StringComparison.OrdinalIgnoreCase))
            {
                hataMesaji = $"Seçili Ollama modeli bulunamadı veya endpoint yanıt vermedi. Sağ üstten yüklü modeli seçin ya da `ollama pull {selectedModel}` çalıştırın.";
                await RefreshModels();
            }

            messages.Add(new ChatMessageDisplay
            {
                Content = $"❌ Hata: {hataMesaji}\n\nOllama'nın çalıştığından emin olun.",
                IsUser = false,
                Timestamp = DateTime.Now
            });
        }
        finally
        {
            isLoading = false;
            isTyping = false;
            streamingContent = "";
            streamingCts?.Dispose();
            streamingCts = null;
            StateHasChanged();
            await ScrollToBottom();
        }
    }

    private void ClearChat()
    {
        messages.Clear();
        conversationHistory.Clear();
        ChatService.ClearHistory();
        streamingCts?.Cancel();
        isLoading = false;
        isTyping = false;
        streamingContent = "";
        lastKnowledgeInfo = string.Empty;
    }

    private async Task<string> BuildAssistantPromptAsync(string userPrompt)
    {
        if (!useKnowledgeBase)
        {
            lastKnowledgeInfo = "Bilgi bankası kapalı.";
            return userPrompt;
        }

        var ilgiliMakaleler = await GetRelevantKnowledgeArticlesAsync(userPrompt);
        if (!ilgiliMakaleler.Any())
        {
            lastKnowledgeInfo = "Bilgi bankasında eşleşen makale bulunamadı.";
            return userPrompt;
        }

        lastKnowledgeInfo = $"Bilgi bankasından {ilgiliMakaleler.Count} makale bağlama eklendi: {string.Join(", ", ilgiliMakaleler.Select(x => x.Baslik).Take(3))}";

        var builder = new StringBuilder();
        builder.AppendLine("Aşağıdaki bilgi bankası kayıtlarını öncelikli bağlam olarak kullan.");
        builder.AppendLine("Bağlam yeterli değilse bunu açıkça belirt ve ardından genel cevap ver.");
        builder.AppendLine("Uydurma bilgi verme.");
        builder.AppendLine();
        builder.AppendLine("Bilgi Bankası Bağlamı:");

        foreach (var makale in ilgiliMakaleler)
        {
            builder.AppendLine($"- Başlık: {makale.Baslik}");

            if (!string.IsNullOrWhiteSpace(makale.Ozet))
            {
                builder.AppendLine($"  Özet: {TemizMetin(makale.Ozet, 300)}");
            }

            var icerik = TemizMetin(makale.Icerik, 700);
            if (!string.IsNullOrWhiteSpace(icerik))
            {
                builder.AppendLine($"  İçerik: {icerik}");
            }

            if (!string.IsNullOrWhiteSpace(makale.Etiketler))
            {
                builder.AppendLine($"  Etiketler: {makale.Etiketler}");
            }

            builder.AppendLine();
        }

        builder.AppendLine($"Kullanıcı sorusu: {userPrompt}");
        return builder.ToString();
    }

    private async Task<List<DestekBilgiBankasi>> GetRelevantKnowledgeArticlesAsync(string prompt)
    {
        var sonuc = new Dictionary<int, DestekBilgiBankasi>();

        foreach (var anahtarKelime in KelimelereAyir(prompt))
        {
            var makaleler = await DestekTalebiService.GetBilgiBankasiAramaAsync(anahtarKelime);
            foreach (var makale in makaleler)
            {
                sonuc.TryAdd(makale.Id, makale);
            }

            if (sonuc.Count >= 5)
            {
                break;
            }
        }

        if (sonuc.Count == 0 && prompt.Length <= 120)
        {
            var dogrudanArama = await DestekTalebiService.GetBilgiBankasiAramaAsync(prompt.Trim());
            foreach (var makale in dogrudanArama)
            {
                sonuc.TryAdd(makale.Id, makale);
            }
        }

        return sonuc.Values.Take(5).ToList();
    }

    private static List<string> KelimelereAyir(string text)
    {
        var anlamsizKelimeler = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            "ve", "veya", "ile", "için", "icin", "ama", "fakat", "gibi", "nasıl", "nasil", "nedir", "olan", "olanlar", "bana", "bir", "bu", "şu", "su", "çok", "cok", "daha"
        };

        return Regex.Split(text.ToLowerInvariant(), @"[^\p{L}\p{N}]+")
            .Where(x => x.Length >= 3 && !anlamsizKelimeler.Contains(x))
            .Distinct()
            .Take(8)
            .ToList();
    }

    private static string TemizMetin(string? html, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(html))
        {
            return string.Empty;
        }

        var text = Regex.Replace(html, "<.*?>", " ");
        text = System.Net.WebUtility.HtmlDecode(text);
        text = Regex.Replace(text, @"\s+", " ").Trim();

        if (text.Length <= maxLength)
        {
            return text;
        }

        return text[..maxLength] + "...";
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await JS.InvokeVoidAsync("eval", "document.getElementById('chatMessages').scrollTop = document.getElementById('chatMessages').scrollHeight");
        }
        catch { }
    }

    private string FormatMessage(string content)
    {
        if (string.IsNullOrEmpty(content)) return content;

        // Escape HTML first
        content = System.Net.WebUtility.HtmlEncode(content);

        // Format code blocks ```code```
        content = System.Text.RegularExpressions.Regex.Replace(
            content,
            @"```(\w+)?\n([\s\S]*?)```",
            match =>
            {
                var lang = match.Groups[1].Value;
                var code = System.Net.WebUtility.HtmlDecode(match.Groups[2].Value.Trim());
                return $"<pre><code class=\"language-{lang}\">{System.Net.WebUtility.HtmlEncode(code)}</code></pre>";
            });

        // Format inline code `code`
        content = System.Text.RegularExpressions.Regex.Replace(
            content,
            @"`([^`]+)`",
            "<code>$1</code>");

        // Format bold **text**
        content = System.Text.RegularExpressions.Regex.Replace(
            content,
            @"\*\*([^*]+)\*\*",
            "<strong>$1</strong>");

        // Format italic *text*
        content = System.Text.RegularExpressions.Regex.Replace(
            content,
            @"(?<!\*)\*([^*]+)\*(?!\*)",
            "<em>$1</em>");

        return content;
    }

    private class ChatMessageDisplay
    {
        public string Content { get; set; } = "";
        public bool IsUser { get; set; }
        public DateTime Timestamp { get; set; }
    }
}
