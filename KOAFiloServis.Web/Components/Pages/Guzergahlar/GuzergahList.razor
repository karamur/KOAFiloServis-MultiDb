@page "/guzergahlar"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using KOAFiloServis.Web.Data
@using Microsoft.EntityFrameworkCore
@using KOAFiloServis.Web.Components.Shared
@inject IGuzergahService GuzergahService
@inject IKurumService KurumService
@inject IAracService AracService
@inject ISoforService SoforService
@inject IKapasiteService KapasiteService
@inject IGuzergahSeferService GuzergahSeferService
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation
@rendermode InteractiveServer

<style>
    .sefer-detay-row > td { background-color: #f8f9fa; padding: 0; }
    .sefer-detay-icerik { padding: .75rem 1rem; border-top: 2px solid #0d6efd; }
    .sefer-tipi-btn { cursor: pointer; min-width: 110px; }
    .guzergah-row.acik { background-color: #e7f1ff !important; }

    /* Sefer Durumu göstergeleri */
    .sefer-durum-wrap { display: inline-flex; flex-direction: column; align-items: center; gap: 4px; line-height: 1; }
    .sefer-pill {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 4px 10px; border-radius: 999px;
        font-size: .78rem; font-weight: 700; letter-spacing: .2px;
    }
    .sefer-pill.ok    { background: #e6f6ec; color: #146c43; border: 1px solid #a7e0bc; }
    .sefer-pill.eksik { background: #fdecec; color: #b02a37; border: 1px solid #f1aeb5; animation: seferPulse 1.6s ease-in-out infinite; }
    @@keyframes seferPulse { 0%,100% { box-shadow: 0 0 0 0 rgba(220,53,69,0); } 50% { box-shadow: 0 0 0 4px rgba(220,53,69,.18); } }
    .sefer-dots { display: inline-flex; gap: 3px; }
    .sefer-dot { width: 10px; height: 10px; border-radius: 50%; border: 1px solid #c7c7c7; background: #fff; }
    .sefer-dot.dolu { background: #198754; border-color: #146c43; }
    .sefer-dot.bos  { background: #fff; border-color: #dc3545; box-shadow: inset 0 0 0 2px #f8d7da; }
</style>

<PageTitle>Güzergahlar</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-signpost me-2"></i>Güzergahlar</h3>
        <div class="d-flex gap-2">
            <div class="btn-group" role="group">
                <button type="button" class="btn @(gorunumModu == "liste" ? "btn-primary" : "btn-outline-primary")" 
                        @onclick="@(() => GorunumDegistir("liste"))" title="Liste Görünümü">
                    <i class="bi bi-list-ul"></i>
                </button>
                <button type="button" class="btn @(gorunumModu == "harita" ? "btn-primary" : "btn-outline-primary")" 
                        @onclick="@(() => GorunumDegistir("harita"))" title="Harita Görünümü">
                    <i class="bi bi-map"></i>
                </button>
            </div>
            <button class="btn btn-primary" @onclick="YeniGuzergah">
                <i class="bi bi-plus-lg me-1"></i>Yeni Güzergah
            </button>
        </div>
    </div>

    @if (guzergahlar == null)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else if (!guzergahlar.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>Henüz güzergah kaydı bulunmamaktadır.
        </div>
    }
    else
    {
        @* Harita Görünümü *@
        @if (gorunumModu == "harita")
        {
            <div class="card mb-3">
                <div class="card-header bg-primary text-white">
                    <i class="bi bi-map me-2"></i>Güzergah Haritası
                    <span class="badge bg-light text-dark ms-2">@guzergahlarWithCoords.Count() güzergah</span>
                </div>
                <div class="card-body p-0">
                    @if (!guzergahlarWithCoords.Any())
                    {
                        <div class="alert alert-warning m-3">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            Koordinat bilgisi olan güzergah bulunmamaktadır. 
                            Güzergahları düzenleyerek koordinat ekleyebilirsiniz.
                        </div>
                    }
                    else
                    {
                        <HaritaGosterici @ref="harita" 
                                        Style="height: 500px; width: 100%;" 
                                        CenterLatitude="39.9208" 
                                        CenterLongitude="32.8541" 
                                        Zoom="6" />
                    }
                </div>
            </div>

            @* Harita altında kısa liste *@
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-list me-2"></i>Güzergah Listesi
                </div>
                <div class="card-body">
                    <div class="row">
                        @foreach (var guzergah in guzergahlar)
                        {
                            <div class="col-md-4 col-lg-3 mb-3">
                                <div class="card h-100 @(guzergah.Aktif ? "" : "border-danger")">
                                    <div class="card-body p-2">
                                        <h6 class="card-title mb-1">
                                            <span class="badge me-1" style="background-color: @(guzergah.RotaRengi ?? "#3388ff")">
                                                @guzergah.GuzergahKodu
                                            </span>
                                        </h6>
                                        <p class="card-text small mb-1">@guzergah.GuzergahAdi</p>
                                        <p class="card-text small text-muted mb-0">
                                            <i class="bi bi-geo-alt-fill text-success"></i> @(guzergah.BaslangicNoktasi ?? "-")
                                            <br/>
                                            <i class="bi bi-geo-alt text-danger"></i> @(guzergah.BitisNoktasi ?? "-")
                                        </p>
                                        @if (guzergah.BaslangicLatitude.HasValue && guzergah.BitisLatitude.HasValue)
                                        {
                                            <span class="badge bg-success mt-1"><i class="bi bi-pin-map"></i> Konumlu</span>
                                        }
                                    </div>
                                    <div class="card-footer p-1">
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => Duzenle(guzergah.Id)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
        else
        {
            @* Liste Görünümü (Mevcut Tablo) *@
            <div class="card mb-3">
                <div class="card-body py-2">
                    <div class="row g-2 align-items-end">
                        <div class="col-md-3">
                            <label class="form-label small mb-1">Kurum / Müşteri Kartı</label>
                            <select class="form-select form-select-sm" @bind="filtreKurumId">
                                <option value="0">Tümü</option>
                                @foreach (var k in kurumlar)
                                {
                                    <option value="@k.Id">@k.KurumAdi</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small mb-1">Cari</label>
                            <select class="form-select form-select-sm" @bind="filtreCariId">
                                <option value="0">Tümü</option>
                                @foreach (var c in CariSecenekleri)
                                {
                                    <option value="@c.Id">@c.Unvan</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small mb-1">Sefer Tipi</label>
                            <select class="form-select form-select-sm" @bind="filtreSeferTipi">
                                <option value="">Tümü</option>
                                <option value="Sabah">Sabah</option>
                                <option value="Aksam">Akşam</option>
                                <option value="SabahAksam">Sabah-Akşam</option>
                                <option value="Saatlik">Saatlik</option>
                            </select>
                        </div>
                        <div class="col-md-1">
                            <label class="form-label small mb-1">Durum</label>
                            <select class="form-select form-select-sm" @bind="filtreDurum">
                                <option value="aktif">Aktif</option>
                                <option value="pasif">Pasif</option>
                                <option value="hepsi">Hepsi</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small mb-1">Arama (Kod / Ad / Plaka / Şoför)</label>
                            <input type="text" class="form-control form-control-sm" @bind="filtreArama" @bind:event="oninput" placeholder="Yazmaya başlayın..." />
                        </div>
                    </div>
                    <div class="mt-2 small text-muted">
                        Toplam: <strong>@FiltrelenmisGuzergahlar.Count()</strong> kayıt gösteriliyor (@guzergahlar.Count toplam)
                        <button class="btn btn-link btn-sm py-0" @onclick="FiltreleriTemizle">Filtreleri Temizle</button>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover table-sm">
                            <thead class="table-dark">
                                <tr>
                                    <th>Kod</th>
                                    <th>Güzergah Adı</th>
                                    <th>Kurum / Müşteri</th>
                                    <th>Cari</th>
                                    <th class="text-center">Kapasite Adı</th>
                                    <th>Varsayılan Araç</th>
                                    <th>Şoför</th>
                                    <th class="text-end">Gelir ₺</th>
                                    <th class="text-end">Gider ₺</th>
                                    <th class="text-center">Konum</th>
                                    <th class="text-center">Durum</th>
                                    <th class="text-center" style="width: 130px;">Sefer Durumu</th>
                                    <th style="width: 150px;">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var guzergah in FiltrelenmisGuzergahlar)
                                {
                                    <tr class="guzergah-row @(acikGuzergahId == guzergah.Id ? "acik" : "")">
                                        <td><strong>@guzergah.GuzergahKodu</strong></td>
                                        <td>@guzergah.GuzergahAdi</td>
                                        <td>@(guzergah.Kurum?.KurumAdi ?? KurumAdiBul(guzergah.CariId) ?? "-")</td>
                                        <td>@(guzergah.Cari?.Unvan ?? "-")</td>
                                        <td class="text-center">@(KapasiteAdiBul(guzergah) ?? guzergah.PersonelSayisi.ToString())</td>
                                        <td>@(guzergah.VarsayilanArac?.AktifPlaka ?? "-")</td>
                                        <td>@(guzergah.VarsayilanSofor?.TamAd ?? "-")</td>
                                        <td class="text-end"><strong class="text-success">@guzergah.GelirFiyat.ToString("N2")</strong></td>
                                        <td class="text-end"><strong class="text-danger">@guzergah.GiderFiyat.ToString("N2")</strong></td>
                                        <td class="text-center">
                                            @if (guzergah.BaslangicLatitude.HasValue && guzergah.BitisLatitude.HasValue)
                                            {
                                                <span class="badge bg-success" title="Koordinatlar tanımlı"><i class="bi bi-pin-map-fill"></i></span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary" title="Koordinat yok"><i class="bi bi-pin-map"></i></span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (guzergah.Aktif)
                                            {
                                                <span class="badge bg-success">Aktif</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Pasif</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @{
                                                var (eslesen, toplam) = SeferEslesmeDurumu(guzergah);
                                                var eksik = toplam - eslesen;
                                                var tamam = eksik == 0;
                                                var titleTxt = tamam
                                                    ? $"Tüm seferlere araç eşleştirildi ({eslesen}/{toplam})"
                                                    : $"DİKKAT: {eksik} sefer için araç eşleştirilmedi ({eslesen}/{toplam})";
                                            }
                                            <div class="sefer-durum-wrap" title="@titleTxt">
                                                @if (tamam)
                                                {
                                                    <span class="sefer-pill ok">
                                                        <i class="bi bi-check-circle-fill"></i>@eslesen / @toplam
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="sefer-pill eksik">
                                                        <i class="bi bi-exclamation-triangle-fill"></i>@eksik EKSİK
                                                        <span class="opacity-75 fw-normal">(@eslesen/@toplam)</span>
                                                    </span>
                                                }
                                                <span class="sefer-dots">
                                                    @for (int i = 0; i < toplam; i++)
                                                    {
                                                        <span class="sefer-dot @(i < eslesen ? "dolu" : "bos")"
                                                              title="@($"Sefer {i + 1}: " + (i < eslesen ? "eşleştirildi" : "eşleştirilmedi"))"></span>
                                                    }
                                                </span>
                                            </div>
                                        </td>
                                        <td>
                                            <button type="button" class="btn btn-sm btn-info text-white me-1"
                                                    @onclick="() => SeferDetayToggle(guzergah)" title="Sefer detaylarını göster/gizle">
                                                <i class="bi @(acikGuzergahId == guzergah.Id ? "bi-chevron-down" : "bi-chevron-right")"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Duzenle(guzergah.Id)" title="Düzenle">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => SilOnay(guzergah)" title="Sil">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    @if (acikGuzergahId == guzergah.Id)
                                    {
                                        <tr class="sefer-detay-row">
                                            <td colspan="13">
                                                <div class="sefer-detay-icerik">
                                                    @SeferDetayPanel(guzergah)
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
</div>

@if (showDeleteModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Silme Onayı</h5>
                    <button type="button" class="btn-close" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body">
                    <p><strong>@silinecekGuzergah?.GuzergahAdi</strong> güzergahını silmek istediğinize emin misiniz?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showDeleteModal = false">İptal</button>
                    <button type="button" class="btn btn-danger" @onclick="Sil">Sil</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Guzergah>? guzergahlar;
    private List<Kurum> kurumlar = new();
    private List<Arac> tumAraclar = new();
    private List<Sofor> tumSoforler = new();
    private List<Kapasite> tumKapasiteler = new();
    private bool showDeleteModal = false;
    private Guzergah? silinecekGuzergah;
    private string gorunumModu = "liste";
    private HaritaGosterici? harita;

    // Sefer detay state
    private int? acikGuzergahId;
    private readonly Dictionary<int, List<SeferDetayKalemi>> seferDetaylari = new();
    private int? kaydedenGuzergahId;
    private int? kaydedildiGuzergahId;

    // Filtreler
    private int filtreKurumId;
    private int filtreCariId;
    private string filtreSeferTipi = string.Empty;
    private string filtreDurum = "aktif";
    private string filtreArama = string.Empty;

    private IEnumerable<Guzergah> guzergahlarWithCoords =>
        guzergahlar?.Where(g => g.BaslangicLatitude.HasValue && g.BaslangicLongitude.HasValue
            && g.BitisLatitude.HasValue && g.BitisLongitude.HasValue) ?? Enumerable.Empty<Guzergah>();

    private IEnumerable<Cari> CariSecenekleri =>
        guzergahlar?
            .Where(g => g.Cari != null)
            .Select(g => g.Cari!)
            .GroupBy(c => c.Id)
            .Select(g => g.First())
            .OrderBy(c => c.Unvan)
            ?? Enumerable.Empty<Cari>();

    private IEnumerable<Guzergah> FiltrelenmisGuzergahlar
    {
        get
        {
            if (guzergahlar == null) return Enumerable.Empty<Guzergah>();
            IEnumerable<Guzergah> q = guzergahlar;

            if (filtreDurum == "aktif") q = q.Where(g => g.Aktif);
            else if (filtreDurum == "pasif") q = q.Where(g => !g.Aktif);

            if (filtreKurumId > 0)
            {
                q = q.Where(g => g.KurumId == filtreKurumId
                    || (g.KurumId == null && kurumlar.Any(k => k.Id == filtreKurumId && k.CariId == g.CariId)));
            }

            if (filtreCariId > 0)
                q = q.Where(g => g.CariId == filtreCariId);

            if (!string.IsNullOrWhiteSpace(filtreSeferTipi)
                && Enum.TryParse<SeferTipi>(filtreSeferTipi, out var st))
                q = q.Where(g => g.SeferTipi == st);

            if (!string.IsNullOrWhiteSpace(filtreArama))
            {
                var ara = filtreArama.Trim();
                q = q.Where(g =>
                    (g.GuzergahKodu ?? "").Contains(ara, StringComparison.OrdinalIgnoreCase)
                    || (g.GuzergahAdi ?? "").Contains(ara, StringComparison.OrdinalIgnoreCase)
                    || (g.BaslangicNoktasi ?? "").Contains(ara, StringComparison.OrdinalIgnoreCase)
                    || (g.BitisNoktasi ?? "").Contains(ara, StringComparison.OrdinalIgnoreCase)
                    || (g.VarsayilanArac != null && (g.VarsayilanArac.AktifPlaka ?? "").Contains(ara, StringComparison.OrdinalIgnoreCase))
                    || (g.VarsayilanSofor != null && (g.VarsayilanSofor.TamAd ?? "").Contains(ara, StringComparison.OrdinalIgnoreCase))
                    || (g.Cari != null && (g.Cari.Unvan ?? "").Contains(ara, StringComparison.OrdinalIgnoreCase))
                );
            }

            return q;
        }
    }

    private string? KurumAdiBul(int cariId)
    {
        if (cariId <= 0) return null;
        return kurumlar.FirstOrDefault(k => k.CariId == cariId)?.KurumAdi;
    }

    private void FiltreleriTemizle()
    {
        filtreKurumId = 0;
        filtreCariId = 0;
        filtreSeferTipi = string.Empty;
        filtreDurum = "aktif";
        filtreArama = string.Empty;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (gorunumModu == "harita" && harita != null && guzergahlarWithCoords.Any())
        {
            await LoadMapData();
        }
    }

    private async Task LoadData()
    {
        guzergahlar = await GuzergahService.GetAllAsync();
        kurumlar = await KurumService.GetAktifAsync();
        tumAraclar = await AracService.GetActiveAsync();
        tumSoforler = await SoforService.GetActiveAsync();
        try
        {
            // Önce aktif olanları, eksikse tümünü dene (pasif edilmiş eski kapasiteler için)
            tumKapasiteler = await KapasiteService.GetActiveAsync() ?? new();
            try
            {
                var hepsi = await KapasiteService.GetAllAsync() ?? new();
                foreach (var k in hepsi)
                {
                    if (!tumKapasiteler.Any(x => x.Id == k.Id))
                        tumKapasiteler.Add(k);
                }
            }
            catch { /* GetAllAsync yoksa sorun değil */ }
        }
        catch { tumKapasiteler = new(); }

        // Kayıtlı sefer detaylarını yükle
        try
        {
            var grup = await GuzergahSeferService.GetAllGroupedAsync();
            seferDetaylari.Clear();
            foreach (var kv in grup)
            {
                seferDetaylari[kv.Key] = kv.Value.Select(s => new SeferDetayKalemi
                {
                    SeferTipi = s.SeferTipi,
                    KapasiteAdi = s.KapasiteAdi,
                    AracId = s.AracId,
                    SoforAd = s.SoforAd,
                    SoforTelefon = s.SoforTelefon,
                    Firma = s.FirmaAdiSerbest
                }).ToList();
            }
        }
        catch { /* sefer yükleme isteyene bırakılır */ }
    }

    private async Task LoadMapData()
    {
        if (harita == null) return;

        await harita.ClearMapAsync();

        var haritaDtoList = guzergahlarWithCoords.Select(g => new HaritaGosterici.GuzergahHaritaDto
        {
            BaslangicLatitude = g.BaslangicLatitude,
            BaslangicLongitude = g.BaslangicLongitude,
            BitisLatitude = g.BitisLatitude,
            BitisLongitude = g.BitisLongitude,
            GuzergahAdi = g.GuzergahAdi,
            BaslangicNoktasi = g.BaslangicNoktasi,
            BitisNoktasi = g.BitisNoktasi,
            RotaRengi = g.RotaRengi
        }).ToList();

        await harita.AddMultipleGuzergahlarAsync(haritaDtoList);
    }

    private async Task GorunumDegistir(string mod)
    {
        gorunumModu = mod;
        StateHasChanged();

        if (mod == "harita")
        {
            await Task.Delay(100); // DOM render için bekle
            if (harita != null)
            {
                await harita.InvalidateSizeAsync();
            }
        }
    }

    private void YeniGuzergah()
    {
        Navigation.NavigateTo("/guzergahlar/yeni");
    }

    private void Duzenle(int id)
    {
        Navigation.NavigateTo($"/guzergahlar/{id}");
    }

    private void SilOnay(Guzergah guzergah)
    {
        silinecekGuzergah = guzergah;
        showDeleteModal = true;
    }

    private async Task Sil()
    {
        if (silinecekGuzergah != null)
        {
            await GuzergahService.DeleteAsync(silinecekGuzergah.Id);
            await LoadData();
        }
        showDeleteModal = false;
        silinecekGuzergah = null;
    }

    // ── Sefer Detay ──────────────────────────────────────────────────
    private (int eslesen, int toplam) SeferEslesmeDurumu(Guzergah g)
    {
        if (seferDetaylari.TryGetValue(g.Id, out var liste) && liste.Count > 0)
        {
            var eslesen = liste.Count(s => s.AracId.HasValue && s.AracId.Value > 0);
            return (eslesen, liste.Count);
        }
        // Detay henüz açılmadıysa: varsayılan sefer sayısı 2; varsayılan araç varsa 2/2, yoksa 0/2
        var varsayilan = g.VarsayilanAracId.HasValue && g.VarsayilanAracId.Value > 0 ? 2 : 0;
        return (varsayilan, 2);
    }

    private string? KapasiteAdiBul(Guzergah g)
    {
        // 0) Öncelik: güzergahın kendi kayıtlı KapasiteAdi alanı
        if (!string.IsNullOrWhiteSpace(g.KapasiteAdi))
            return g.KapasiteAdi.Trim();

        if (g.PersonelSayisi <= 0) return null;

        var hedef = g.PersonelSayisi;
        var hedefStr = hedef.ToString();

        // 1) Birleştirilmiş rakam eşleşmesi (öncelik): "16+1" -> 161
        foreach (var k in tumKapasiteler)
        {
            var ad = (k.KapasiteAdi ?? string.Empty).Trim();
            if (string.IsNullOrWhiteSpace(ad)) continue;
            var rakam = new string(ad.Where(char.IsDigit).ToArray());
            if (rakam == hedefStr) return ad;
        }

        // 2) Tam eşleşme: KapasiteAdi'ndaki ilk sayı bloğu PersonelSayisi'ye eşitse
        foreach (var k in tumKapasiteler)
        {
            var ad = (k.KapasiteAdi ?? string.Empty).Trim();
            if (string.IsNullOrWhiteSpace(ad)) continue;
            if (IlkSayiyiAl(ad) == hedef) return ad;
        }

        // 3) Toplam eşleşme: Sayıların toplamı PersonelSayisi'ye eşitse
        foreach (var k in tumKapasiteler)
        {
            var ad = (k.KapasiteAdi ?? string.Empty).Trim();
            if (string.IsNullOrWhiteSpace(ad)) continue;
            if (SayiToplamiAl(ad) == hedef) return ad;
        }

        // 4) Sayısal eşitlik (parse edilebilir tüm sayılar)
        foreach (var k in tumKapasiteler)
        {
            var ad = (k.KapasiteAdi ?? string.Empty).Trim();
            if (string.IsNullOrWhiteSpace(ad)) continue;
            if (int.TryParse(ad, out var n) && n == hedef) return ad;
        }

        return hedef.ToString();
    }

    private static int IlkSayiyiAl(string s)
    {
        int i = 0;
        while (i < s.Length && !char.IsDigit(s[i])) i++;
        int basla = i;
        while (i < s.Length && char.IsDigit(s[i])) i++;
        return basla < i && int.TryParse(s.AsSpan(basla, i - basla), out var n) ? n : -1;
    }

    private static int SayiToplamiAl(string s)
    {
        int toplam = 0; int i = 0; bool varMi = false;
        while (i < s.Length)
        {
            if (char.IsDigit(s[i]))
            {
                int basla = i;
                while (i < s.Length && char.IsDigit(s[i])) i++;
                if (int.TryParse(s.AsSpan(basla, i - basla), out var n)) { toplam += n; varMi = true; }
            }
            else i++;
        }
        return varMi ? toplam : -1;
    }

    private void SeferDetayToggle(Guzergah g)
    {
        if (acikGuzergahId == g.Id)
        {
            acikGuzergahId = null;
            return;
        }
        acikGuzergahId = g.Id;
        if (!seferDetaylari.ContainsKey(g.Id))
        {
            seferDetaylari[g.Id] = new List<SeferDetayKalemi>
            {
                YeniSeferKalemi(g),
                YeniSeferKalemi(g)
            };
        }
    }

    private SeferDetayKalemi YeniSeferKalemi(Guzergah g) => new()
    {
        SeferTipi = g.SeferTipi,
        KapasiteAdi = KapasiteAdiBul(g),
        AracId = g.VarsayilanAracId,
        SoforAd = g.VarsayilanSofor?.TamAd,
        SoforTelefon = g.VarsayilanSofor?.Telefon,
        Firma = g.Firma?.FirmaAdi
    };

    private void SeferSayisiDegistir(Guzergah g, int yeniSayi)
    {
        if (yeniSayi < 1) yeniSayi = 1;
        if (yeniSayi > 50) yeniSayi = 50;
        var liste = seferDetaylari[g.Id];
        if (liste.Count < yeniSayi)
        {
            while (liste.Count < yeniSayi)
                liste.Add(YeniSeferKalemi(g));
        }
        else if (liste.Count > yeniSayi)
        {
            liste.RemoveRange(yeniSayi, liste.Count - yeniSayi);
        }
    }

    private void TumSeferlereUygula(Guzergah g)
    {
        var liste = seferDetaylari[g.Id];
        if (liste.Count == 0) return;
        var ilk = liste[0];
        for (int i = 1; i < liste.Count; i++)
        {
            liste[i] = new SeferDetayKalemi
            {
                SeferTipi = ilk.SeferTipi,
                KapasiteAdi = ilk.KapasiteAdi,
                AracId = ilk.AracId,
                SoforAd = ilk.SoforAd,
                SoforTelefon = ilk.SoforTelefon,
                Firma = ilk.Firma
            };
        }
    }

    private async Task SeferleriKaydet(Guzergah g)
    {
        if (!seferDetaylari.TryGetValue(g.Id, out var liste)) return;
        try
        {
            kaydedenGuzergahId = g.Id;
            kaydedildiGuzergahId = null;
            StateHasChanged();

            var entities = liste.Select(k => new GuzergahSefer
            {
                GuzergahId = g.Id,
                SeferTipi = k.SeferTipi,
                KapasiteAdi = k.KapasiteAdi,
                AracId = k.AracId,
                SoforAd = k.SoforAd,
                SoforTelefon = k.SoforTelefon,
                FirmaAdiSerbest = k.Firma
            }).ToList();

            await GuzergahSeferService.ReplaceAllAsync(g.Id, entities);
            kaydedildiGuzergahId = g.Id;
        }
        finally
        {
            kaydedenGuzergahId = null;
            StateHasChanged();
        }
    }

    private async Task PlakaDegisti(SeferDetayKalemi kalem, int? aracId)
    {
        kalem.AracId = aracId;
        kalem.SoforAd = null;
        kalem.SoforTelefon = null;
        kalem.Firma = null;
        if (!aracId.HasValue) return;

        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            var arac = await ctx.Araclar
                .AsNoTracking()
                .Include(a => a.KiralikCari)
                .Include(a => a.KomisyoncuCari)
                .Include(a => a.TasimaTedarikci)
                    .ThenInclude(t => t!.Personeller)
                .FirstOrDefaultAsync(a => a.Id == aracId.Value);
            if (arac == null) return;

            if (arac.SahiplikTipi == AracSahiplikTipi.Tedarikci && arac.TasimaTedarikci != null)
            {
                kalem.Firma = arac.TasimaTedarikci.Unvan;
                var sofor = arac.TasimaTedarikci.Personeller?
                    .FirstOrDefault(s => s.Aktif && s.Gorev == PersonelGorev.Sofor);
                kalem.SoforAd = sofor?.TamAd ?? arac.TasimaTedarikci.YetkiliKisi;
                kalem.SoforTelefon = sofor?.Telefon ?? arac.TasimaTedarikci.Telefon;
            }
            else
            {
                kalem.Firma = arac.KiralikCari?.Unvan ?? arac.KomisyoncuCari?.Unvan;

                // Özmal: Bu araçla eşleşmiş FiloGuzergahEslestirme üzerinden şoförü bul
                var eslesme = await ctx.Set<FiloGuzergahEslestirme>()
                    .AsNoTracking()
                    .Where(e => e.AracId == aracId.Value && !e.IsDeleted)
                    .OrderByDescending(e => e.Id)
                    .FirstOrDefaultAsync();
                if (eslesme != null)
                {
                    var sofor = await ctx.Soforler.AsNoTracking()
                        .FirstOrDefaultAsync(s => s.Id == eslesme.SoforId);
                    if (sofor != null)
                    {
                        kalem.SoforAd = sofor.TamAd;
                        kalem.SoforTelefon = sofor.Telefon;
                    }
                }
            }
        }
        catch { /* en kötü senaryoda alanlar boş kalır */ }
        StateHasChanged();
    }

