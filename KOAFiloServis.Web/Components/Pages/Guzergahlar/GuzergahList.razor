@page "/guzergahlar"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@using KOAFiloServis.Web.Components.Shared
@inject IGuzergahService GuzergahService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Güzergahlar</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-signpost me-2"></i>Güzergahlar</h3>
        <div class="d-flex gap-2">
            <div class="btn-group" role="group">
                <button type="button" class="btn @(gorunumModu == "liste" ? "btn-primary" : "btn-outline-primary")" 
                        @onclick="@(() => GorunumDegistir("liste"))" title="Liste Görünümü">
                    <i class="bi bi-list-ul"></i>
                </button>
                <button type="button" class="btn @(gorunumModu == "harita" ? "btn-primary" : "btn-outline-primary")" 
                        @onclick="@(() => GorunumDegistir("harita"))" title="Harita Görünümü">
                    <i class="bi bi-map"></i>
                </button>
            </div>
            <button class="btn btn-primary" @onclick="YeniGuzergah">
                <i class="bi bi-plus-lg me-1"></i>Yeni Güzergah
            </button>
        </div>
    </div>

    @if (guzergahlar == null)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else if (!guzergahlar.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>Henüz güzergah kaydı bulunmamaktadır.
        </div>
    }
    else
    {
        @* Harita Görünümü *@
        @if (gorunumModu == "harita")
        {
            <div class="card mb-3">
                <div class="card-header bg-primary text-white">
                    <i class="bi bi-map me-2"></i>Güzergah Haritası
                    <span class="badge bg-light text-dark ms-2">@guzergahlarWithCoords.Count() güzergah</span>
                </div>
                <div class="card-body p-0">
                    @if (!guzergahlarWithCoords.Any())
                    {
                        <div class="alert alert-warning m-3">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            Koordinat bilgisi olan güzergah bulunmamaktadır. 
                            Güzergahları düzenleyerek koordinat ekleyebilirsiniz.
                        </div>
                    }
                    else
                    {
                        <HaritaGosterici @ref="harita" 
                                        Style="height: 500px; width: 100%;" 
                                        CenterLatitude="39.9208" 
                                        CenterLongitude="32.8541" 
                                        Zoom="6" />
                    }
                </div>
            </div>

            @* Harita altında kısa liste *@
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-list me-2"></i>Güzergah Listesi
                </div>
                <div class="card-body">
                    <div class="row">
                        @foreach (var guzergah in guzergahlar)
                        {
                            <div class="col-md-4 col-lg-3 mb-3">
                                <div class="card h-100 @(guzergah.Aktif ? "" : "border-danger")">
                                    <div class="card-body p-2">
                                        <h6 class="card-title mb-1">
                                            <span class="badge me-1" style="background-color: @(guzergah.RotaRengi ?? "#3388ff")">
                                                @guzergah.GuzergahKodu
                                            </span>
                                        </h6>
                                        <p class="card-text small mb-1">@guzergah.GuzergahAdi</p>
                                        <p class="card-text small text-muted mb-0">
                                            <i class="bi bi-geo-alt-fill text-success"></i> @(guzergah.BaslangicNoktasi ?? "-")
                                            <br/>
                                            <i class="bi bi-geo-alt text-danger"></i> @(guzergah.BitisNoktasi ?? "-")
                                        </p>
                                        @if (guzergah.BaslangicLatitude.HasValue && guzergah.BitisLatitude.HasValue)
                                        {
                                            <span class="badge bg-success mt-1"><i class="bi bi-pin-map"></i> Konumlu</span>
                                        }
                                    </div>
                                    <div class="card-footer p-1">
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => Duzenle(guzergah.Id)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
        else
        {
            @* Liste Görünümü (Mevcut Tablo) *@
            <div class="card">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Güzergah Kodu</th>
                                    <th>Güzergah Adı</th>
                                    <th>Firma</th>
                                    <th>Başlangıç</th>
                                    <th>Bitiş</th>
                                    <th>Gelir Fiyatı</th>
                                    <th>Gider Fiyatı</th>
                                    <th>Konum</th>
                                    <th>Durum</th>
                                    <th style="width: 120px;">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var guzergah in guzergahlar)
                                {
                                    <tr>
                                        <td><strong>@guzergah.GuzergahKodu</strong></td>
                                        <td>@guzergah.GuzergahAdi</td>
                                        <td>@guzergah.Cari?.Unvan</td>
                                        <td>@guzergah.BaslangicNoktasi</td>
                                        <td>@guzergah.BitisNoktasi</td>
                                        <td><strong class="text-success">@guzergah.GelirFiyat.ToString("N2") ₺</strong></td>
                                        <td><strong class="text-danger">@guzergah.GiderFiyat.ToString("N2") ₺</strong></td>
                                        <td>
                                            @if (guzergah.BaslangicLatitude.HasValue && guzergah.BitisLatitude.HasValue)
                                            {
                                                <span class="badge bg-success" title="Koordinatlar tanımlı">
                                                    <i class="bi bi-pin-map-fill"></i>
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary" title="Koordinat yok">
                                                    <i class="bi bi-pin-map"></i>
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            @if (guzergah.Aktif)
                                            {
                                                <span class="badge bg-success">Aktif</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Pasif</span>
                                            }
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Duzenle(guzergah.Id)" title="Düzenle">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => SilOnay(guzergah)" title="Sil">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
</div>

@if (showDeleteModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Silme Onayı</h5>
                    <button type="button" class="btn-close" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body">
                    <p><strong>@silinecekGuzergah?.GuzergahAdi</strong> güzergahını silmek istediğinize emin misiniz?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showDeleteModal = false">İptal</button>
                    <button type="button" class="btn btn-danger" @onclick="Sil">Sil</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Guzergah>? guzergahlar;
    private bool showDeleteModal = false;
    private Guzergah? silinecekGuzergah;
    private string gorunumModu = "liste";
    private HaritaGosterici? harita;

    private IEnumerable<Guzergah> guzergahlarWithCoords => 
        guzergahlar?.Where(g => g.BaslangicLatitude.HasValue && g.BaslangicLongitude.HasValue 
            && g.BitisLatitude.HasValue && g.BitisLongitude.HasValue) ?? Enumerable.Empty<Guzergah>();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (gorunumModu == "harita" && harita != null && guzergahlarWithCoords.Any())
        {
            await LoadMapData();
        }
    }

    private async Task LoadData()
    {
        guzergahlar = await GuzergahService.GetAllAsync();
    }

    private async Task LoadMapData()
    {
        if (harita == null) return;

        await harita.ClearMapAsync();

        var haritaDtoList = guzergahlarWithCoords.Select(g => new HaritaGosterici.GuzergahHaritaDto
        {
            BaslangicLatitude = g.BaslangicLatitude,
            BaslangicLongitude = g.BaslangicLongitude,
            BitisLatitude = g.BitisLatitude,
            BitisLongitude = g.BitisLongitude,
            GuzergahAdi = g.GuzergahAdi,
            BaslangicNoktasi = g.BaslangicNoktasi,
            BitisNoktasi = g.BitisNoktasi,
            RotaRengi = g.RotaRengi
        }).ToList();

        await harita.AddMultipleGuzergahlarAsync(haritaDtoList);
    }

    private async Task GorunumDegistir(string mod)
    {
        gorunumModu = mod;
        StateHasChanged();

        if (mod == "harita")
        {
            await Task.Delay(100); // DOM render için bekle
            if (harita != null)
            {
                await harita.InvalidateSizeAsync();
            }
        }
    }

    private void YeniGuzergah()
    {
        Navigation.NavigateTo("/guzergahlar/yeni");
    }

    private void Duzenle(int id)
    {
        Navigation.NavigateTo($"/guzergahlar/{id}");
    }

    private void SilOnay(Guzergah guzergah)
    {
        silinecekGuzergah = guzergah;
        showDeleteModal = true;
    }

    private async Task Sil()
    {
        if (silinecekGuzergah != null)
        {
            await GuzergahService.DeleteAsync(silinecekGuzergah.Id);
            await LoadData();
        }
        showDeleteModal = false;
        silinecekGuzergah = null;
    }
}
