@page "/personel-tasima/tedarikciler/yeni"
@page "/personel-tasima/tedarikciler/{Id:int}"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Services
@inject ITasimaTedarikciService TedarikciService
@inject IGuzergahService GuzergahService
@inject ICariService CariService
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Tedarikçi @(Id is null ? "Yeni" : "Düzenle")</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">
            <i class="bi bi-truck me-2"></i>
            @(Id is null ? "Yeni Personel Taşıma Tedarikçisi" : $"Tedarikçi: {tedarikci.Unvan}")
        </h3>
        <a class="btn btn-outline-secondary" href="/personel-tasima/tedarikciler">
            <i class="bi bi-arrow-left me-1"></i> Listeye Dön
        </a>
    </div>

    @if (yukleniyor)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else
    {
        <ul class="nav nav-tabs mb-3">
            <li class="nav-item"><button class="nav-link @(aktifTab == "bilgi" ? "active" : "")" @onclick='() => aktifTab = "bilgi"'>Bilgiler</button></li>
            @if (Id.HasValue)
            {
                <li class="nav-item"><button class="nav-link @(aktifTab == "personel" ? "active" : "")" @onclick='() => aktifTab = "personel"'>Personel (@(personeller?.Count ?? 0))</button></li>
                <li class="nav-item"><button class="nav-link @(aktifTab == "arac" ? "active" : "")" @onclick='() => aktifTab = "arac"'>Araçlar (@(araclar?.Count ?? 0))</button></li>
                <li class="nav-item"><button class="nav-link @(aktifTab == "is" ? "active" : "")" @onclick='() => aktifTab = "is"'>İşler / Güzergahlar (@(isler?.Count ?? 0))</button></li>
            }
        </ul>

        @if (aktifTab == "bilgi")
        {
            <EditForm Model="tedarikci" OnValidSubmit="Kaydet">
                <DataAnnotationsValidator />
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Tedarikçi Kodu</label>
                        <input class="form-control" @bind="tedarikci.TedarikciKodu" placeholder="Otomatik" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Ünvan *</label>
                        <input class="form-control" @bind="tedarikci.Unvan" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Aktif</label>
                        <div class="form-check form-switch mt-2">
                            <input class="form-check-input" type="checkbox" @bind="tedarikci.Aktif" />
                            <label class="form-check-label">@(tedarikci.Aktif ? "Aktif" : "Pasif")</label>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Yetkili Kişi</label>
                        <input class="form-control" @bind="tedarikci.YetkiliKisi" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Telefon</label>
                        <input class="form-control" @bind="tedarikci.Telefon" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">E-posta</label>
                        <input class="form-control" @bind="tedarikci.Email" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Vergi Dairesi</label>
                        <input class="form-control" @bind="tedarikci.VergiDairesi" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Vergi No</label>
                        <input class="form-control" @bind="tedarikci.VergiNo" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Cari Bağlantısı</label>
                        <select class="form-select" @bind="tedarikci.CariId">
                            <option value="">— Seçiniz —</option>
                            @foreach (var c in cariler)
                            {
                                <option value="@c.Id">@c.CariKodu - @c.Unvan</option>
                            }
                        </select>
                        <div class="form-text">Mali analiz/fatura için tek kaynak.</div>
                    </div>

                    <div class="col-md-12">
                        <label class="form-label">Adres</label>
                        <input class="form-control" @bind="tedarikci.Adres" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">İl</label>
                        <input class="form-control" @bind="tedarikci.Il" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">İlçe</label>
                        <input class="form-control" @bind="tedarikci.Ilce" />
                    </div>

                    <div class="col-12"><hr /><h6>Sözleşme</h6></div>
                    <div class="col-md-3">
                        <label class="form-label">Sözleşme No</label>
                        <input class="form-control" @bind="tedarikci.SozlesmeNo" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Başlangıç</label>
                        <input type="date" class="form-control" @bind="tedarikci.SozlesmeBaslangicTarihi" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Bitiş</label>
                        <input type="date" class="form-control" @bind="tedarikci.SozlesmeBitisTarihi" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Vars. Sefer Ücreti (₺)</label>
                        <input type="number" step="0.01" class="form-control" @bind="tedarikci.VarsayilanSeferUcreti" />
                    </div>

                    <div class="col-12">
                        <label class="form-label">Notlar</label>
                        <textarea class="form-control" rows="2" @bind="tedarikci.Notlar"></textarea>
                    </div>
                </div>

                <div class="mt-4 d-flex justify-content-between">
                    <div>
                        @if (Id.HasValue)
                        {
                            <button type="button" class="btn btn-outline-danger" @onclick="Sil">
                                <i class="bi bi-trash me-1"></i> Sil
                            </button>
                        }
                    </div>
                    <div>
                        <button class="btn btn-primary" type="submit">
                            <i class="bi bi-check-circle me-1"></i> Kaydet
                        </button>
                    </div>
                </div>
            </EditForm>
        }
        else if (aktifTab == "personel" && Id.HasValue)
        {
            <div class="alert alert-info small mb-2">
                Bu sekmede tedarikçiye atanan mevcut <strong>Personel</strong> kayıtları listelenir. Yeni personel eklemek için <a href="/personel/yeni">Personel modülünden</a> kayıt açıp <em>Taşıma Tedarikçisi</em> alanını seçmeniz yeterlidir.
            </div>
            @if (personeller is null || !personeller.Any())
            { <div class="text-muted">Bu tedarikçiye bağlı personel bulunamadı.</div> }
            else
            {
                <table class="table table-sm">
                    <thead><tr><th>Ad Soyad</th><th>Görev</th><th>Telefon</th><th>TC</th><th></th></tr></thead>
                    <tbody>
                    @foreach (var p in personeller)
                    {
                        <tr>
                            <td>@p.TamAd</td>
                            <td>@p.Gorev</td>
                            <td>@p.Telefon</td>
                            <td>@p.TcKimlikNo</td>
                            <td class="text-end"><a href="/personel/@p.Id" class="btn btn-sm btn-outline-primary">Detay</a></td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
        }
        else if (aktifTab == "arac" && Id.HasValue)
        {
            <div class="alert alert-info small mb-2">
                Bu sekmede tedarikçiye atanan mevcut <strong>Araç</strong> kayıtları listelenir. Belge takibi (ruhsat, sigorta, muayene, vb.) <em>Araç Belgeleri</em> tablosu üzerinden tek kaynaktan yapılır.
            </div>
            @if (araclar is null || !araclar.Any())
            { <div class="text-muted">Bu tedarikçiye bağlı araç bulunamadı.</div> }
            else
            {
                <table class="table table-sm">
                    <thead><tr><th>Plaka</th><th>Marka/Model</th><th>Tip</th><th>Koltuk</th><th></th></tr></thead>
                    <tbody>
                    @foreach (var a in araclar)
                    {
                        <tr>
                            <td><strong>@a.AktifPlaka</strong></td>
                            <td>@a.Marka @a.Model</td>
                            <td>@a.AracTipi</td>
                            <td>@a.KoltukSayisi</td>
                            <td class="text-end"><a href="/araclar/@a.Id" class="btn btn-sm btn-outline-primary">Detay</a></td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
        }
        else if (aktifTab == "is" && Id.HasValue)
        {
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="text-muted small">Tedarikçinin hizmet verdiği güzergahlar / iş sözleşmeleri.</div>
                <button class="btn btn-sm btn-success" @onclick="YeniIsAc"><i class="bi bi-plus-circle me-1"></i> Yeni İş</button>
            </div>

            @if (yeniIsAcik)
            {
                <div class="card mb-3">
                    <div class="card-body">
                        <div class="row g-2">
                            <div class="col-md-4">
                                <label class="form-label small">Güzergah *</label>
                                <select class="form-select form-select-sm" @bind="yeniIs.GuzergahId">
                                    <option value="0">— Seçiniz —</option>
                                    @foreach (var g in guzergahlar)
                                    {
                                        <option value="@g.Id">@g.GuzergahKodu - @g.GuzergahAdi</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small">Başlangıç</label>
                                <input type="date" class="form-control form-control-sm" @bind="yeniIs.BaslangicTarihi" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small">Bitiş</label>
                                <input type="date" class="form-control form-control-sm" @bind="yeniIs.BitisTarihi" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small">Sefer Ücreti</label>
                                <input type="number" step="0.01" class="form-control form-control-sm" @bind="yeniIs.SeferUcreti" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small">Aylık Ücret</label>
                                <input type="number" step="0.01" class="form-control form-control-sm" @bind="yeniIs.AylikUcret" />
                            </div>
                            <div class="col-md-12">
                                <label class="form-label small">Açıklama</label>
                                <input class="form-control form-control-sm" @bind="yeniIs.Aciklama" />
                            </div>
                        </div>
                        <div class="mt-2 text-end">
                            <button class="btn btn-sm btn-secondary me-1" @onclick="() => yeniIsAcik = false">Vazgeç</button>
                            <button class="btn btn-sm btn-primary" @onclick="IsKaydet">Kaydet</button>
                        </div>
                    </div>
                </div>
            }

            @if (isler is null || !isler.Any())
            { <div class="text-muted">Henüz iş kaydı yok.</div> }
            else
            {
                <table class="table table-sm">
                    <thead><tr><th>Güzergah</th><th>Başlangıç</th><th>Bitiş</th><th>Sefer ₺</th><th>Aylık ₺</th><th>Durum</th><th></th></tr></thead>
                    <tbody>
                    @foreach (var i in isler)
                    {
                        <tr>
                            <td>@i.Guzergah?.GuzergahKodu - @i.Guzergah?.GuzergahAdi</td>
                            <td>@i.BaslangicTarihi.ToString("dd.MM.yyyy")</td>
                            <td>@i.BitisTarihi?.ToString("dd.MM.yyyy")</td>
                            <td>@i.SeferUcreti?.ToString("N2")</td>
                            <td>@i.AylikUcret?.ToString("N2")</td>
                            <td>@i.Durum</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => IsSil(i.Id)"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
        }
    }
</div>

@code {
    [Parameter] public int? Id { get; set; }

    private TasimaTedarikci tedarikci = new();
    private List<Cari> cariler = new();
    private List<Guzergah> guzergahlar = new();
    private List<Sofor>? personeller;
    private List<Arac>? araclar;
    private List<TasimaTedarikciIs>? isler;

    private string aktifTab = "bilgi";
    private bool yukleniyor = true;
    private bool yeniIsAcik = false;
    private TasimaTedarikciIs yeniIs = new();

    protected override async Task OnParametersSetAsync()
    {
        yukleniyor = true;
        cariler = await CariService.GetAllAsync();
        guzergahlar = await GuzergahService.GetAllAsync();

        if (Id.HasValue)
        {
            tedarikci = await TedarikciService.GetAsync(Id.Value) ?? new TasimaTedarikci();
            await IliskileriYukle();
        }
        else
        {
            tedarikci = new TasimaTedarikci { Aktif = true };
        }
        yukleniyor = false;
    }

    private async Task IliskileriYukle()
    {
        if (!Id.HasValue) return;
        personeller = await TedarikciService.GetTedarikciPersonelleriAsync(Id.Value);
        araclar = await TedarikciService.GetTedarikciAraclariAsync(Id.Value);
        isler = await TedarikciService.GetIslerAsync(Id.Value);
    }

    private async Task Kaydet()
    {
        if (Id.HasValue)
        {
            await TedarikciService.UpdateAsync(tedarikci);
        }
        else
        {
            var olusan = await TedarikciService.CreateAsync(tedarikci);
            Nav.NavigateTo($"/personel-tasima/tedarikciler/{olusan.Id}");
            return;
        }
        await IliskileriYukle();
    }

    private async Task Sil()
    {
        if (!Id.HasValue) return;
        await TedarikciService.DeleteAsync(Id.Value);
        Nav.NavigateTo("/personel-tasima/tedarikciler");
    }

    private void YeniIsAc()
    {
        yeniIs = new TasimaTedarikciIs
        {
            TasimaTedarikciId = Id ?? 0,
            BaslangicTarihi = DateTime.Today,
            Durum = TasimaTedarikciIsDurum.Aktif
        };
        yeniIsAcik = true;
    }

    private async Task IsKaydet()
    {
        if (yeniIs.GuzergahId <= 0 || !Id.HasValue) return;
        yeniIs.TasimaTedarikciId = Id.Value;
        await TedarikciService.CreateIsAsync(yeniIs);
        yeniIsAcik = false;
        await IliskileriYukle();
    }

    private async Task IsSil(int isId)
    {
        await TedarikciService.DeleteIsAsync(isId);
        await IliskileriYukle();
    }
}
