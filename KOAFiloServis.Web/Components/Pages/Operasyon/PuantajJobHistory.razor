@page "/puantaj/jobs"
@using KOAFiloServis.Shared.Entities
@using KOAFiloServis.Web.Data
@using KOAFiloServis.Web.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@attribute [Authorize(Roles = "Admin,Operasyon,Muhasebeci,HoldingYoneticisi")]
@rendermode InteractiveServer

<PageTitle>Puantaj Job Geçmişi</PageTitle>

<div class="container-fluid px-3">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0"><i class="bi bi-cpu me-2 text-primary"></i>Puantaj Otomasyon</h4>
            <p class="text-muted small mb-0">Aylık otomatik hesaplama durumu ve geçmişi</p>
        </div>
        <div>
            @if (isAdmin)
            {
                <button class="btn btn-primary btn-sm" @onclick="ProcessAllAsync" disabled="@isProcessing">
                    @if (isProcessing)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                        <span>Çalışıyor...</span>
                    }
                    else
                    {
                        <i class="bi bi-play-fill me-1"></i>
                        <span>Geçen Ayı Hesapla (Tüm Firmalar)</span>
                    }
                </button>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert @(statusIsError ? "alert-danger" : "alert-success") alert-dismissible fade show py-2" role="alert">
            @statusMessage
            <button type="button" class="btn-close btn-sm" @onclick="() => statusMessage = null"></button>
        </div>
    }

    @* ── Summary Cards ─────────────────────────────────────────────── *@
    <div class="row g-2 mb-3">
        <div class="col-md-3">
            <div class="card summary-card @(lastRunStatus == "Running" ? "border-warning" : lastRunStatus == "Completed" ? "border-success" : lastRunStatus == "Failed" ? "border-danger" : "border-secondary")">
                <div class="card-body py-2 px-3">
                    <div class="text-muted small">Son Çalışma</div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge @StatusBadgeClass(lastRunStatus)">@(lastRunStatus ?? "---")</span>
                        <small class="text-muted">@(lastRunTime?.ToString("dd.MM.yyyy HH:mm") ?? "Henüz çalışmadı")</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card summary-card border-success">
                <div class="card-body py-2 px-3">
                    <div class="text-muted small">Başarılı</div>
                    <div class="fs-5 fw-bold text-success">@successCount</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card summary-card border-danger">
                <div class="card-body py-2 px-3">
                    <div class="text-muted small">Hatalı / Atlanan</div>
                    <div class="fs-5 fw-bold text-danger">@failedCount / @skippedCount</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card summary-card border-info">
                <div class="card-body py-2 px-3">
                    <div class="text-muted small">Son Çalışma Süresi</div>
                    <div class="fs-5 fw-bold text-info">@(lastDuration > 0 ? $"{lastDuration}sn" : "---")</div>
                </div>
            </div>
        </div>
    </div>

    @* ── History Grid ──────────────────────────────────────────────── *@
    <div class="card">
        <div class="card-header py-2 d-flex justify-content-between align-items-center">
            <span><i class="bi bi-list-ul me-1"></i>Execution Geçmişi</span>
            <button class="btn btn-outline-secondary btn-sm" @onclick="RefreshAsync">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Tarih</th>
                            <th>Dönem</th>
                            <th>Tetikleyen</th>
                            <th class="text-end">Süre</th>
                            <th class="text-end">Operasyon</th>
                            <th class="text-end">Puantaj</th>
                            <th class="text-center">Durum</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var job in history)
                        {
                            <tr>
                                <td class="small">@job.Baslangic?.ToString("dd.MM HH:mm")</td>
                                <td>@job.Yil/@job.Ay.ToString("D2")@(job.Versiyon > 0 ? $" (V{job.Versiyon})" : "")</td>
                                <td class="small">
                                    <span class="badge bg-light text-dark">@job.Tetikleyen</span>
                                </td>
                                <td class="text-end small">@(job.SureSn > 0 ? $"{job.SureSn}sn" : "---")</td>
                                <td class="text-end small">@job.IslenenOperasyon</td>
                                <td class="text-end small">@job.UretilenPuantaj</td>
                                <td class="text-center">
                                    <span class="badge @StatusBadgeClass(job.Durum)">@job.Durum</span>
                                </td>
                                <td class="text-end">
                                    @if (job.Durum == "Failed" || job.Durum == "Running")
                                    {
                                        <button class="btn btn-outline-warning btn-sm py-0"
                                                @onclick="() => RetryTenantAsync(job)"
                                                disabled="@isProcessing"
                                                title="@(job.HataMesaji ?? "")">
                                            <i class="bi bi-arrow-repeat me-1"></i>Retry
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (!history.Any())
            {
                <div class="text-center text-muted py-4">
                    <i class="bi bi-inbox fs-3"></i>
                    <p class="mt-2">Henüz job execution kaydı yok.</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .summary-card { border-left: 4px solid; }
</style>

@code {
    [Inject] private IPuantajJobService JobService { get; set; } = null!;
    [Inject] private IDbContextFactory<ApplicationDbContext> DbFactory { get; set; } = null!;

    private List<JobHistoryRow> history = new();
    private bool isProcessing;
    private bool isAdmin;
    private string? statusMessage;
    private bool statusIsError;

    private string? lastRunStatus = "---";
    private DateTime? lastRunTime;
    private int successCount;
    private int failedCount;
    private int skippedCount;
    private int lastDuration;

    protected override async Task OnInitializedAsync()
    {
        // Admin + HoldingYoneticisi tüm firmaları görebilir
        // TODO: role check via authorization service — şimdilik basit
        isAdmin = true; // Sayfa zaten Authorize ile kısıtlı
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var raw = await db.PuantajJobExecutions
                .Where(j => !j.IsDeleted)
                .OrderByDescending(j => j.CreatedAt)
                .Take(50)
                .Select(j => new
                {
                    j.Id, j.FirmaId, j.Yil, j.Ay, j.Tetikleyen,
                    Durum = (int)j.Durum,
                    j.Baslangic, j.Bitis, j.Versiyon,
                    j.IslenenOperasyon, j.UretilenPuantaj, j.HataMesaji
                })
                .ToListAsync();

            history = raw.Select(j => new JobHistoryRow
            {
                Id = j.Id,
                FirmaId = j.FirmaId,
                Yil = j.Yil,
                Ay = j.Ay,
                Tetikleyen = j.Tetikleyen,
                Durum = ((PuantajJobExecutionDurum)j.Durum).ToString(),
                Baslangic = j.Baslangic,
                Bitis = j.Bitis,
                SureSn = j.Baslangic.HasValue && j.Bitis.HasValue
                    ? (int?)(j.Bitis!.Value - j.Baslangic!.Value).TotalSeconds
                    : null,
                Versiyon = j.Versiyon,
                IslenenOperasyon = j.IslenenOperasyon,
                UretilenPuantaj = j.UretilenPuantaj,
                HataMesaji = j.HataMesaji != null && j.HataMesaji.Length > 150
                    ? j.HataMesaji.Substring(0, 150) + "..."
                    : j.HataMesaji
            }).ToList();

            // Summary
            var completed = history.Where(h => h.Durum == "Completed").ToList();
            var failed = history.Where(h => h.Durum == "Failed").ToList();
            var skipped = history.Where(h => h.Durum == "Skipped").ToList();

            successCount = completed.Count;
            failedCount = failed.Count;
            skippedCount = skipped.Count;

            var lastCompleted = completed.FirstOrDefault();
            lastRunStatus = lastCompleted?.Durum ?? history.FirstOrDefault()?.Durum ?? "---";
            lastRunTime = lastCompleted?.Baslangic ?? history.FirstOrDefault()?.Baslangic;
            lastDuration = lastCompleted?.SureSn ?? 0;
        }
        catch (Exception ex)
        {
            statusMessage = $"Yüklenirken hata: {ex.Message}";
            statusIsError = true;
        }
    }

    private async Task ProcessAllAsync()
    {
        isProcessing = true;
        statusMessage = null;
        try
        {
            var now = DateTime.UtcNow;
            var yil = now.Month == 1 ? now.Year - 1 : now.Year;
            var ay = now.Month == 1 ? 12 : now.Month - 1;

            var result = await JobService.ProcessAllTenantsAsync(yil, ay, "Manuel");
            statusMessage = $"{yil}/{ay:D2} tamamlandı: {result.Durum}";
            statusIsError = result.Durum == PuantajJobExecutionDurum.Failed;
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            statusMessage = $"Hata: {ex.Message}";
            statusIsError = true;
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task RetryTenantAsync(JobHistoryRow row)
    {
        if (row.FirmaId == null) return;
        isProcessing = true;
        statusMessage = null;
        try
        {
            await JobService.ProcessTenantAsync(row.FirmaId.Value, null, row.Yil, row.Ay, "Manuel-Retry");
            statusMessage = $"Firma {row.FirmaId} {row.Yil}/{row.Ay:D2} retry başarılı.";
            statusIsError = false;
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            statusMessage = $"Retry hatası: {ex.Message}";
            statusIsError = true;
        }
        finally
        {
            isProcessing = false;
        }
    }

    private static string StatusBadgeClass(string? durum) => durum switch
    {
        "Running" => "bg-warning text-dark",
        "Completed" => "bg-success",
        "PartialSuccess" => "bg-info",
        "Failed" => "bg-danger",
        "Skipped" => "bg-secondary",
        _ => "bg-light text-dark"
    };

    private class JobHistoryRow
    {
        public int Id { get; set; }
        public int? FirmaId { get; set; }
        public int Yil { get; set; }
        public int Ay { get; set; }
        public string Tetikleyen { get; set; } = "";
        public string Durum { get; set; } = "";
        public DateTime? Baslangic { get; set; }
        public DateTime? Bitis { get; set; }
        public int? SureSn { get; set; }
        public int Versiyon { get; set; }
        public int IslenenOperasyon { get; set; }
        public int UretilenPuantaj { get; set; }
        public string? HataMesaji { get; set; }
    }
}
